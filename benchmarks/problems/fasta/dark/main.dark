// Fasta Benchmark - DNA Sequence Generation
// Uses linear congruential generator for pseudo-random numbers (float-based selection)
// Computes checksum of generated DNA sequences

// LCG constants: IM=139968, IA=3877, IC=29573

// Get element from ALU at position i (mod 287)
def getAlu(aluBytes: List<Int64>, i: Int64) : Int64 =
    match Stdlib.List.getAt<Int64>(aluBytes, i % 287) with
    | Some(v) -> v
    | None -> 0

// Generate repeat fasta checksum
def makeRepeatFasta(aluBytes: List<Int64>, n: Int64, i: Int64, checksum: Int64) : Int64 =
    if i >= n then checksum
    else
        let c = getAlu(aluBytes, i) in
        let newChecksum = (checksum + c * (i + 1)) % 1000000007 in
        makeRepeatFasta(aluBytes, n, i + 1, newChecksum)

// Convert probability table to cumulative distribution
def makeCumulative(table: List<(Int64, Float)>, running: Float) : List<(Int64, Float)> =
    match Stdlib.List.head<(Int64, Float)>(table) with
    | None -> []
    | Some(item) ->
        let c = Stdlib.Tuple2.first<Int64, Float>(item) in
        let p = Stdlib.Tuple2.second<Int64, Float>(item) in
        let newRunning = running + p in
        match Stdlib.List.tail<(Int64, Float)>(table) with
        | None -> [(c, newRunning)]
        | Some(rest) ->
            let restCum = makeCumulative(rest, newRunning) in
            Stdlib.List.push<(Int64, Float)>(restCum, (c, newRunning))

// Select element from cumulative table
def selectRandom(table: List<(Int64, Float)>, r: Float, idx: Int64) : Int64 =
    match Stdlib.List.getAt(table, idx) with
    | None -> 0
    | Some(item) ->
        let c = Stdlib.Tuple2.first(item) in
        let p = Stdlib.Tuple2.second(item) in
        if r < p then c
        else
            if idx + 1 >= Stdlib.List.length(table) then c
            else selectRandom(table, r, idx + 1)

// Generate random fasta checksum - returns (checksum, seed)
def makeRandomFasta(n: Int64, table: List<(Int64, Float)>, seed: Int64, i: Int64, checksum: Int64) : (Int64, Int64) =
    if i >= n then (checksum, seed)
    else
        let newSeed = (seed * 3877 + 29573) % 139968 in
        let r = Stdlib.Int64.toFloat(newSeed) / 139968.0 in
        let c = selectRandom(table, r, 0) in
        let newChecksum = (checksum + c * (i + 1)) % 1000000007 in
        makeRandomFasta(n, table, newSeed, i + 1, newChecksum)

// Full size: n=100000
// 2n=200000 repeat, 3n=300000 random iub, 5n=500000 random homo

// ALU sequence bytes (287 chars)
let aluBytes = [71, 71, 67, 67, 71, 71, 71, 67, 71, 67, 71, 71, 84, 71, 71, 67, 84, 67, 65, 67, 71, 67, 67, 84, 71, 84, 65, 65, 84, 67, 67, 67, 65, 71, 67, 65, 67, 84, 84, 84, 71, 71, 71, 65, 71, 71, 67, 67, 71, 65, 71, 71, 67, 71, 71, 71, 67, 71, 71, 65, 84, 67, 65, 67, 67, 84, 71, 65, 71, 71, 84, 67, 65, 71, 71, 65, 71, 84, 84, 67, 71, 65, 71, 65, 67, 67, 65, 71, 67, 67, 84, 71, 71, 67, 67, 65, 65, 67, 65, 84, 71, 71, 84, 71, 65, 65, 65, 67, 67, 67, 67, 71, 84, 67, 84, 67, 84, 65, 67, 84, 65, 65, 65, 65, 65, 84, 65, 67, 65, 65, 65, 65, 65, 84, 84, 65, 71, 67, 67, 71, 71, 71, 67, 71, 84, 71, 71, 84, 71, 71, 67, 71, 67, 71, 67, 71, 67, 67, 84, 71, 84, 65, 65, 84, 67, 67, 67, 65, 71, 67, 84, 65, 67, 84, 67, 71, 71, 71, 65, 71, 71, 67, 84, 71, 65, 71, 71, 67, 65, 71, 71, 65, 71, 65, 65, 84, 67, 71, 67, 84, 84, 71, 65, 65, 67, 67, 67, 71, 71, 71, 65, 71, 71, 67, 71, 71, 65, 71, 71, 84, 84, 71, 67, 65, 71, 84, 71, 65, 71, 67, 67, 71, 65, 71, 65, 84, 67, 71, 67, 71, 67, 67, 65, 67, 84, 71, 67, 65, 67, 84, 67, 67, 65, 71, 67, 67, 84, 71, 71, 71, 67, 71, 65, 67, 65, 71, 65, 71, 67, 71, 65, 71, 65, 67, 84, 67, 67, 71, 84, 67, 84, 67, 65, 65, 65, 65, 65] in
let n = 100000 in
let iub = [(97, 0.27), (99, 0.12), (103, 0.12), (116, 0.27), (66, 0.02), (68, 0.02), (72, 0.02), (75, 0.02), (77, 0.02), (78, 0.02), (82, 0.02), (83, 0.02), (86, 0.02), (87, 0.02), (89, 0.02)] in
let homosapiens = [(97, 0.3029549426680), (99, 0.1979883004921), (103, 0.1975473066391), (116, 0.3015094502008)] in
let iubCum = makeCumulative(iub, 0.0) in
let homoCum = makeCumulative(homosapiens, 0.0) in
let c1 = makeRepeatFasta(aluBytes, n * 2, 0, 0) in
let result2 = makeRandomFasta(n * 3, iubCum, 42, 0, 0) in
let c2 = Stdlib.Tuple2.first<Int64, Int64>(result2) in
let seed2 = Stdlib.Tuple2.second<Int64, Int64>(result2) in
let result3 = makeRandomFasta(n * 5, homoCum, seed2, 0, 0) in
let c3 = Stdlib.Tuple2.first<Int64, Int64>(result3) in
let total = (c1 + c2 + c3) % 1000000007 in
Stdlib.Int64.toString(total)
