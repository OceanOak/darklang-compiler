// Tak (Takeuchi) Benchmark - Quick check version

def tak(x: Int64, y: Int64, z: Int64) : Int64 =
    if x <= y then z
    else tak(tak(x - 1, y, z), tak(y - 1, z, x), tak(z - 1, x, y))

def repeat(n: Int64, acc: Int64) : Int64 =
    if n <= 0 then acc
    else repeat(n - 1, tak(24, 16, 8))

// Reduced: tak(18, 12, 6) instead of tak(24, 16, 8)
tak(18, 12, 6)
