// Float literal tests
// Note: Output format trims trailing zeros

// Basic float literals
1.0 = 1.0
0.5 = 0.5
3.14 = 3.14
2.5 = 2.5

// Zero
0.0 = 0.0

// Float with integer-like values
5.0 = 5.0
10.0 = 10.0
100.0 = 100.0

// Small fractional values
0.25 = 0.25
0.99 = 0.99
0.01 = 0.01

// Negative floats
-1.0 = -1.0
-0.5 = -0.5
-3.14 = -3.14
-0.50 = -0.5
-0.01 = -0.01

// Unary negation of float variables
let x = 1.5 in -x = -1.5  // floats neg var

// Float arithmetic
1.0 + 2.0 = 3.0
3.0 - 1.0 = 2.0
2.0 * 3.0 = 6.0
6.0 / 2.0 = 3.0

// Chained float operations
1.0 + 2.0 + 3.0 = 6.0
10.0 / 2.0 / 2.0 = 2.5

// Nested float operations with let bindings
let a = 1.0 + 2.0 in a = 3.0
let a = 1.0 + 2.0 in let b = 3.0 - 1.0 in a * b = 6.0
(1.0 + 2.0) * (3.0 - 1.0) = 6.0

// =====================================================
// Float function parameters
// Regression tests for bugs found during benchmark work
// =====================================================

// Float parameter in binary operation
// Bug: c + c was returning 0.00 instead of 6.00 (return type inference failed)
def doubleFloat(c: Float) : Float = c + c doubleFloat(3.0) = 6.0

// Float parameter returned directly (should work - baseline)
def identityFloat(c: Float) : Float = c identityFloat(3.0) = 3.0

// Float parameter with literal addition
def addFour(c: Float) : Float = c + 4.0 addFour(3.0) = 7.0

// Float parameter with let binding and operation
def useLocalFloat(c: Float) : Float = let x = 4.0 in c + x useLocalFloat(3.0) = 7.0

// Two float parameters
def addFloats(a: Float, b: Float) : Float = a + b addFloats(1.5, 2.5) = 4.0

// Two float parameters - division
def divFloats(a: Float, b: Float) : Float = a / b divFloats(1.0, 3.0) = 0.33333333333

// Two float parameters - subtraction
def subFloats(a: Float, b: Float) : Float = a - b subFloats(5.0, 3.0) = 2.0

// Two float parameters - multiplication
def mulFloats(a: Float, b: Float) : Float = a * b mulFloats(2.0, 3.0) = 6.0

// Three float parameters
def sum3Floats(a: Float, b: Float, c: Float) : Float = a + b + c sum3Floats(1.0, 2.0, 3.0) = 6.0

// Float list pattern matching should preserve element types
let l = [1.5, 2.5] in match l with | [x, y] -> x + y | _ -> 0.0 = 4.0

// Four float parameters (tests D12-D15 temp allocation)
def sum4Floats(a: Float, b: Float, c: Float, d: Float) : Float = a + b + c + d sum4Floats(1.0, 2.0, 3.0, 4.0) = 10.0

// Mixed float and int parameters
def mixedParams(sign: Float, i: Int64) : Float = let divisor = Stdlib.Int64.toFloat(2 * i + 1) in sign / divisor mixedParams(1.0, 1) = 0.33333333333

// Float param with stdlib call
def floatWithStdlib(c: Float) : Int64 = Stdlib.Float.toInt(c) floatWithStdlib(3.7) = 3

// Float param with multiple operations
def floatChainedOps(x: Float) : Float = (x + 1.0) * 2.0 floatChainedOps(2.0) = 6.0

// =====================================================
// Float comparisons in functions
// =====================================================

// Float comparison returning bool
def isPositiveFloat(x: Float) : Bool = x > 0.0 isPositiveFloat(1.0) = true
def isPositiveFloat(x: Float) : Bool = x > 0.0 isPositiveFloat(-1.0) = false

// Float equality
def floatEq(a: Float, b: Float) : Bool = a == b floatEq(1.0, 1.0) = true
def floatEq(a: Float, b: Float) : Bool = a == b floatEq(1.0, 2.0) = false

// Float less than
def floatLt(a: Float, b: Float) : Bool = a < b floatLt(1.0, 2.0) = true
def floatLt(a: Float, b: Float) : Bool = a < b floatLt(2.0, 1.0) = false

// Float greater than or equal
def floatGte(a: Float, b: Float) : Bool = a >= b floatGte(2.0, 2.0) = true
def floatGte(a: Float, b: Float) : Bool = a >= b floatGte(1.0, 2.0) = false

// Float in if-then-else with parameters
def floatIfThen(a: Int64, b: Int64, c: Float) : Float = if a >= b then c else 0.0 floatIfThen(1, 1, 5.0) = 5.0
def floatIfElse(a: Int64, b: Int64, c: Float) : Float = if a >= b then c else 0.0 floatIfElse(0, 1, 5.0) = 0.0

// Recursive function with float accumulator
def floatSumLoop(i: Int64, n: Int64, acc: Float) : Float = if i >= n then acc else floatSumLoop(i + 1, n, acc + 1.0) floatSumLoop(0, 5, 0.0) = 5.0

// Leibniz pi approximation (uses float in recursive control flow)
def leibnizLoop(i: Int64, n: Int64, sum: Float, sign: Float) : Float = if i >= n then sum * 4.0 else let term = sign / Stdlib.Int64.toFloat(2 * i + 1) in leibnizLoop(i + 1, n, sum + term, Stdlib.Float.negate(sign)) def leibnizPi(n: Int64) : Float = leibnizLoop(0, n, 0.0, 1.0) leibnizPi(10) = 3.04183961892

// =====================================================
// Return type inference via temporary variables
// Tests that computed values stored in let-bindings have
// correct types tracked through the TypeMap. Regression
// test for TInt64 fallback removal in getExprReturnType.
// =====================================================

// Float computed from two int-to-float conversions stored in a temp
def floatViaTemp(a: Int64, b: Int64) : Float = let x = Stdlib.Int64.toFloat(a) in let y = Stdlib.Int64.toFloat(b) in let result = x + y in result floatViaTemp(3, 4) = 7.0

// Float computed through nested let-bindings
def nestedFloatLets(n: Int64) : Float = let a = Stdlib.Int64.toFloat(n) in let b = a * 2.0 in let c = b + 1.0 in c nestedFloatLets(5) = 11.0

// Float returned from deeply nested computation
def deepNestedFloat(x: Int64) : Float = let f1 = Stdlib.Int64.toFloat(x) in let f2 = f1 + f1 in let f3 = f2 * f2 in let f4 = f3 / 2.0 in f4 deepNestedFloat(3) = 18.0

// =====================================================
// Nested if-then-else with float results
// Regression test: ensures result register is properly marked as float
// when either branch of an if-expression returns Float64
// =====================================================

// Simple nested if returning float - just testing the result value
if true then (if true then 1.0 else 2.0) else 3.0 = 1.0
if true then (if false then 1.0 else 2.0) else 3.0 = 2.0
if false then (if true then 1.0 else 2.0) else 3.0 = 3.0

// Nested if result used in float arithmetic
(if true then (if true then 1.0 else 2.0) else 3.0) + 0.5 = 1.5
(if true then (if false then 1.0 else 2.0) else 3.0) + 0.5 = 2.5
(if false then (if true then 1.0 else 2.0) else 3.0) + 0.5 = 3.5

// Mutation #173: Nested if with let bindings in branches
// Tests that float result registers are properly marked when branches contain let bindings
// The then-branch returns a Register (from let binding), else-branch returns FloatSymbol
(if true then (let x = 1.5 in x) else 2.0) + 0.5 = 2.0
(if false then (let x = 1.5 in x) else 2.0) + 0.5 = 2.5
// Both branches with let bindings
(if true then (let a = 1.0 in a + 0.5) else (let b = 2.0 in b + 0.5)) + 1.0 = 2.5
(if false then (let a = 1.0 in a + 0.5) else (let b = 2.0 in b + 0.5)) + 1.0 = 3.5
// Nested if inside let binding with float result used in arithmetic
let r = (if true then (if true then 3.0 else 4.0) else 5.0) in r * 2.0 = 6.0
// Triple nested if with float results
(if true then (if true then (if true then 1.0 else 2.0) else 3.0) else 4.0) + 0.5 = 1.5
