(true && true) = true
(true && false) = false
(false && true) = false
(false && false) = false
(true && Builtin.testRuntimeError "msg") = error="&& only supports Booleans"
(true && 5L) = error="&& only supports Booleans"
(false && 5L) = error="&& only supports Booleans"
//TODO bring back short-circuiting
(false && Builtin.testRuntimeError "msg") = false

(Builtin.testRuntimeError "msg1" && Builtin.testRuntimeError "msg2") = error="&& only supports Booleans"

(5L && true) = error="&& only supports Booleans"
(true |> (&&) true) = true
(true |> (&&) false) = false
(false |> (&&) true) = false
(false |> (&&) false) = false
