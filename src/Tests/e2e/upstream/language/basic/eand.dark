(true && true) = true
(true && false) = false
(false && true) = false
(false && false) = false
(true && Builtin.testRuntimeError "msg") = exit=1 stderr="msg"
(true && 5L) = error="&& only supports Booleans"
(false && 5L) = error="&& only supports Booleans"
//TODO bring back short-circuiting
//(false && Builtin.testRuntimeError "msg") = false

(Builtin.testRuntimeError "msg1" && Builtin.testRuntimeError "msg2") = exit=1 stderr="msg1"
(5 && true) = error="&& only supports Booleans"
(true |> (&&) true) = true
(true |> (&&) false) = false
(false |> (&&) true) = false
(false |> (&&) false) = false
