$"""test {"1"}""" = "test 1"

(let one = "1" in $"test {one}") = "test 1"

(let one = 1.0 in $"test {one}") = error="Type mismatch in variable one: expected String, got Float"

(let one = 1L in $"test {one}") = error="Type mismatch in variable one: expected String, got Int64"

(let name = "John"
 let age = "30"
 $"Name: {name}, Age: {age} years old.") = "Name: John, Age: 30 years old."

(let two = 2L in "test 1" == $"test {one}") = error="Undefined variable: one"

(let one = 1L in $"test {Stdlib.Int64.toString one}") = "test 1"
