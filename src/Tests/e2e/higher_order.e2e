// E2E tests for higher-order functions (functions as arguments)

// =====================================================
// Named Function as Argument
// =====================================================

// Pass named function as argument and call it
def apply(f: (Int64) -> Int64, x: Int64): Int64 = f(x) def inc(n: Int64): Int64 = n + 1 apply(inc, 5) = 6

// Two-argument function passed as argument
def apply2(f: (Int64, Int64) -> Int64, a: Int64, b: Int64): Int64 = f(a, b) def add(x: Int64, y: Int64): Int64 = x + y apply2(add, 3, 4) = 7

// Pass named function and use with multiple values
def twice(f: (Int64) -> Int64, x: Int64): Int64 = f(f(x)) def double(n: Int64): Int64 = n * 2 twice(double, 5) = 20

// =====================================================
// Lambda as Argument (no captures)
// =====================================================

// Pass simple lambda as argument
def apply(f: (Int64) -> Int64, x: Int64): Int64 = f(x) apply((y: Int64) => y + 1, 5) = 6

// Lambda with multiplication
def apply(f: (Int64) -> Int64, x: Int64): Int64 = f(x) apply((y: Int64) => y * 2, 21) = 42

// Two-argument lambda
def apply2(f: (Int64, Int64) -> Int64, a: Int64, b: Int64): Int64 = f(a, b) apply2((a: Int64, b: Int64) => a * b, 6, 7) = 42

// =====================================================
// Lambda with Captures as Argument
// =====================================================

// Pass capturing lambda - closure support
def apply(f: (Int64) -> Int64, x: Int64): Int64 = f(x) let base = 10 in apply((y: Int64) => y + base, 5) = 15

// Two variables captured
def apply(f: (Int64) -> Int64, x: Int64): Int64 = f(x) let a = 10 in let b = 20 in apply((y: Int64) => y + a + b, 12) = 42

// Capture and multiply
def apply(f: (Int64) -> Int64, x: Int64): Int64 = f(x) let factor = 7 in apply((y: Int64) => y * factor, 6) = 42

// =====================================================
// Composed Function Applications
// =====================================================

// Apply function twice using higher-order function
def twice(f: (Int64) -> Int64, x: Int64): Int64 = f(f(x)) twice((y: Int64) => y + 1, 5) = 7

// Twice with capturing lambda
def twice(f: (Int64) -> Int64, x: Int64): Int64 = f(f(x)) let inc = 3 in twice((y: Int64) => y + inc, 5) = 11

// =====================================================
// Nested Lambdas (CPS-style)
// =====================================================

// Nested lambda passed as continuation
def withCont(x: Int64, cont: (Int64) -> Int64): Int64 = cont(x + 1) withCont(5, (r: Int64) => r * 2) = 12

// Two levels of nesting - inner lambda calls outer function
def cps1(x: Int64, k: (Int64) -> Int64): Int64 = k(x) def cps2(x: Int64): Int64 = cps1(x + 1, (r: Int64) => r * 2) cps2(5) = 12

// Three levels of CPS-style nesting
def step(x: Int64, k: (Int64) -> Int64): Int64 = k(x + 1) step(1, (a: Int64) => step(a, (b: Int64) => step(b, (c: Int64) => c))) = 4

// Nested lambda capturing outer lambda's parameter
def outer(f: (Int64) -> Int64, x: Int64): Int64 = f(x) def inner(g: (Int64) -> Int64, y: Int64): Int64 = g(y) outer((a: Int64) => inner((b: Int64) => a + b, 10), 32) = 42

// CPS-style with captured variables
def cpsAdd(x: Int64, k: (Int64) -> Int64): Int64 = k(x) let base = 10 in cpsAdd(5, (r: Int64) => r + base) = 15

// Capturing function parameter in nested lambda (requires proper type tracking)
def apply(f: (Int64) -> Int64, x: Int64): Int64 = f(x) def wrapper(k: (Int64) -> Int64, x: Int64): Int64 = apply((r: Int64) => k(r), x) wrapper((n: Int64) => n * 2, 21) = 42

// =====================================================
// Multiple FuncRefs (tests wrapper name uniqueness)
// =====================================================

// Pass two different named functions as values - each needs unique wrapper
def apply(f: (Int64) -> Int64, x: Int64): Int64 = f(x) def inc(n: Int64): Int64 = n + 1 def dec(n: Int64): Int64 = n - 1 apply(inc, 10) + apply(dec, 10) = 20

// =====================================================
// Multiple FuncRefs Counter Test (Mutation #53)
// =====================================================
// Tests that the wrapper counter increments correctly in generateFuncWrapper.
// With mutation (+ -> -), the counter decrements instead of incrementing when
// generating wrappers for named functions used as values.
// This tests 3+ named functions to ensure all wrappers get unique names.

// Three named functions used as values - each should get unique wrapper
def applyF(f: (Int64) -> Int64, x: Int64): Int64 = f(x) def add1(n: Int64): Int64 = n + 1 def add2(n: Int64): Int64 = n + 2 def add3(n: Int64): Int64 = n + 3 applyF(add1, 10) + applyF(add2, 10) + applyF(add3, 10) = 36

// =====================================================
// FuncRef with Non-Int64 Types (tests correct type propagation)
// =====================================================
// Tests that FuncRef wrappers use the actual function signature types
// instead of defaulting to TInt64. Before the fix, these would generate
// wrappers with incorrect Int64 types.

// FuncRef with Bool parameter and return type
def applyBool(f: (Bool) -> Bool, x: Bool): Bool = f(x) def notBool(b: Bool): Bool = if b then false else true applyBool(notBool, true) = false

// FuncRef with Bool return, testing truthiness
def applyBool2(f: (Bool) -> Bool, x: Bool): Bool = f(x) def identity(b: Bool): Bool = b applyBool2(identity, true) = true

// FuncRef with Float parameter and return type
def applyFloat(f: (Float) -> Float, x: Float): Float = f(x) def doubleFloat(n: Float): Float = n * 2.0 applyFloat(doubleFloat, 21.0) = 42.0

// FuncRef with multiple non-Int64 parameters
def apply2Floats(f: (Float, Float) -> Float, a: Float, b: Float): Float = f(a, b) def addFloats(x: Float, y: Float): Float = x + y apply2Floats(addFloats, 3.5, 4.5) = 8.0

// FuncRef with String parameter and return type
def applyStr(f: (String) -> String, s: String): String = f(s) def addBang(s: String): String = s ++ "!" applyStr(addBang, "hello") = hello!

// FuncRef with mixed types (Int64 param, Bool return)
def checkPositive(f: (Int64) -> Bool, n: Int64): Bool = f(n) def isPositive(x: Int64): Bool = x > 0 checkPositive(isPositive, 5) = true

// FuncRef with mixed types (Bool param, Int64 return)
def boolToNum(f: (Bool) -> Int64, b: Bool): Int64 = f(b) def fromBool(b: Bool): Int64 = if b then 1 else 0 boolToNum(fromBool, true) = 1
