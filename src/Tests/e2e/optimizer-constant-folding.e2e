// Optimizer Constant Folding Tests
//
// These tests verify that the optimizer correctly folds constants.
// This exercises:
// - Unary operation folding (negation, not)
// - Constant propagation through variables
// - Combined optimizations

// ===================================================================
// Unary Operation Folding
// ===================================================================
// Test that negation and not are folded correctly

// Negation through variables (can't be folded at parse time)
let x = 5 in -x = -5
let x = -10 in -x = 10
let x = 0 in -x = 0

// Negation of expressions
let x = 3 in let y = 2 in -(x + y) = -5
let x = 10 in let y = 3 in -(x - y) = -7

// Boolean not through variables
let b = true in !b = false
let b = false in !b = true

// Nested not
let b = true in !!b = true
let b = false in !!b = false

// ===================================================================
// Constant Propagation
// ===================================================================
// Verify constants propagate through multiple let bindings

// Simple propagation
let x = 10 in x = 10
let x = 10 in let y = x in y = 10
let x = 10 in let y = x in let z = y in z = 10

// Propagation with arithmetic
let x = 5 in let y = x + 3 in y = 8
let x = 10 in let y = x * 2 in let z = y + 1 in z = 21

// ===================================================================
// Combined Optimizations
// ===================================================================
// Test that multiple optimizations work together

// Const fold + DCE
let unused = 1 + 2 in let x = 5 in x + 1 = 6

// Const prop + const fold
let a = 3 in let b = 4 in a * b = 12
let a = 10 in let b = a + 5 in let c = b * 2 in c = 30

// Negation + const prop + const fold
let x = 5 in let y = -x in let z = y + 10 in z = 5

// ===================================================================
// Multi-pass Optimization (requires multiple optimizer iterations)
// ===================================================================
// These tests require the optimizer to run multiple passes to fully optimize.
// Each pass enables further optimizations in subsequent passes.

// Chain of propagation and folding requiring multiple passes
// Pass 1: propagate a=2 into b=a+1, fold to b=3
// Pass 2: propagate b=3 into c=b+2, fold to c=5
// Pass 3: propagate c=5 into d=c+3, fold to d=8
// Pass 4: propagate d=8 into result
let a = 2 in let b = a + 1 in let c = b + 2 in let d = c + 3 in d = 8

// ===================================================================
// Strength Reduction (power-of-2 optimizations)
// ===================================================================
// These tests verify that multiplication/division/modulo by powers of 2
// are correctly optimized to shift/bitwise operations.
//
// IMPORTANT: The modulo optimization (x % n -> x & (n-1)) changes semantics
// for negative dividends. For signed integers:
//   - x % n gives result with sign of x (e.g., -7 % 4 = -3)
//   - x & (n-1) is always non-negative (e.g., -7 & 3 = 1)
// The optimizer applies this transformation, so we test the optimized behavior.
//
// NOTE: We use function parameters to prevent constant propagation from
// replacing the variable with its constant value before strength reduction runs.

// Modulo by power of 2 with negative dividend (tests tryLog2 boundary check)
// Without optimization: -7 % 2 = -1, but with optimization: -7 & 1 = 1
def mod2(x: Int64) : Int64 = x % 2 mod2(-7) = 1

// ===================================================================
// Return Statement Constant Propagation
// ===================================================================
// These tests verify that the optimizer correctly tracks changes when
// constant propagation occurs in Return statements. This exercises the
// optimizeAExpr Return case at line 335 (atom' <> atom comparison).

// Simple return with propagated constant
// The optimizer should propagate x=42 into the Return(x) -> Return(42)
let x = 42 in x = 42

// Return propagation through if-else branches (tests changed flag propagation)
// Both branches have Return statements that need constant propagation
def branchReturn(cond: Bool) : Int64 =
  let x = 100 in
    if cond then x else x + 1
branchReturn(true) = 100
branchReturn(false) = 101

// Chain of propagations where final return uses propagated value
// Tests that multiple optimization passes work correctly
let a = 1 in let b = a + 1 in let c = b + 1 in let d = c + 1 in let e = d + 1 in e = 5

// ===================================================================
// If Statement Condition Optimization
// ===================================================================
// These tests verify that the optimizer correctly tracks changes when
// substituting conditions in If statements. This exercises the
// optimizeAExpr If case at line 383 (cond' <> cond comparison).

// If with aliased condition that gets substituted to a literal
// The condition alias gets substituted with true, which then folds the if
let flag = true in let alias = flag in if alias then 42 else 0 = 42
let flag = false in let alias = flag in if alias then 0 else 99 = 99

// Nested if with aliased conditions
// Tests change tracking propagation through nested if statements
let outer = true in let inner = outer in if outer then (if inner then 1 else 2) else 3 = 1

// If with aliased condition and complex branch values
// Tests that branch optimization is tracked correctly alongside condition substitution
let cond = true in let alias = cond in if alias then (let x = 5 in x + 1) else (let y = 10 in y + 2) = 6

// Multiple levels of aliasing before if condition
// Each alias adds to the substitution environment
let a = true in let b = a in let c = b in if c then 100 else 200 = 100

// If condition aliased from function parameter
// Tests aliasing with runtime values (not compile-time constants)
def testCondAlias(flag: Bool) : Int64 = let alias = flag in if alias then 10 else 20
testCondAlias(true) = 10
testCondAlias(false) = 20

// Nested if with different aliased conditions from parameters
def testNestedCondAlias(outer: Bool, inner: Bool) : Int64 = let outerAlias = outer in let innerAlias = inner in if outerAlias then (if innerAlias then 1 else 2) else 3
testNestedCondAlias(true, true) = 1
testNestedCondAlias(true, false) = 2
testNestedCondAlias(false, true) = 3
testNestedCondAlias(false, false) = 3

// ===================================================================
// Let Change Flag Propagation
// ===================================================================
// These tests verify that the optimizer correctly propagates change flags
// through Let bindings at line 367 (cexprChanged || bodyChanged).
// The key is to create Let bindings that are:
// 1. NOT beta-reduced (cexpr must not be a simple Atom)
// 2. NOT dead code eliminated (the variable must be used)
// 3. Have changes in either cexpr OR body (but potentially not both)

// Let with unchanging cexpr (runtime Prim) but changing body
// a = x + y cannot fold at compile time (x, y are parameters)
// b = 1 + 2 folds to 3, then is beta-reduced since it becomes Atom(3)
// The outer Let (a = x + y) has cexprChanged=false, bodyChanged=true
// Correct: returns (Let(a, x+y, a+3), true)
// Mutation (|| -> &&): would return (Let(a, x+y, a+3), false) - wrong!
def testLetChangeFlag(x: Int64, y: Int64) : Int64 =
  let a = x + y in
  let b = 1 + 2 in
  a + b
testLetChangeFlag(10, 20) = 33

// Chain where outer binding can't fold but inner bindings fold
// This tests change flag propagation through nested Let nodes
def testNestedLetChangeFlag(x: Int64) : Int64 =
  let a = x * 2 in      // Can't fold (x is param), but result is used
  let b = 3 + 4 in      // Folds to 7, beta-reduced
  let c = b + 5 in      // After b→7, becomes 7+5=12, beta-reduced
  a + c
testNestedLetChangeFlag(5) = 22

// Multiple non-foldable bindings with foldable ones interleaved
def testInterleavedChangeFlags(x: Int64, y: Int64) : Int64 =
  let a = x + 1 in      // Can't fully fold (x is param), a = x + 1
  let b = 2 + 3 in      // Folds to 5, beta-reduced
  let c = y + a in      // Can't fold (y, a are runtime), uses a
  let d = 4 + 5 in      // Folds to 9, beta-reduced
  c + d                 // c + 9
testInterleavedChangeFlags(10, 20) = 40

// ===================================================================
// If Change Flag Propagation (|| vs &&)
// ===================================================================
// These tests verify that the optimizer correctly uses || (not &&) when
// combining change flags from the condition and branches of an If expression.
// Line 383: (If (cond', thenBranch', elseBranch'), cond' <> cond || thenChanged || elseChanged)
//
// The key is to create an If where:
// 1. The condition doesn't change (cond' = cond) - so that part is false
// 2. Only ONE branch changes (the other doesn't)
// 3. The overall changed flag should be true (with ||), but would be false (with &&)
// 4. This incorrect false would stop multi-pass optimization early

// Test where only thenBranch has changes
// The condition is a runtime parameter (won't change)
// The then-branch has constant folding (1+2 -> 3)
// The else-branch is a simple literal (no change)
// With ||: changed = false || true || false = true (correct)
// With &&: changed = false && true && false = false (WRONG - stops optimization early)
def testIfChangeFlagThenOnly(flag: Bool) : Int64 =
  if flag then
    let x = 1 + 2 in
    let y = x + 3 in
    y
  else
    100
testIfChangeFlagThenOnly(true) = 6
testIfChangeFlagThenOnly(false) = 100

// Test where only elseBranch has changes
// Same principle but changes are in the else branch
def testIfChangeFlagElseOnly(flag: Bool) : Int64 =
  if flag then
    200
  else
    let x = 5 + 5 in
    let y = x + 10 in
    y
testIfChangeFlagElseOnly(true) = 200
testIfChangeFlagElseOnly(false) = 20

// Multi-pass optimization through If with single-branch changes
// This tests that the change flag correctly triggers additional passes
// The If is nested inside a Let binding, so the If's change flag must
// propagate up correctly to trigger subsequent optimization passes.
//
// Structure after parsing (simplified):
//   let result = (if flag then (let a = 2+3 in let b = a+1 in b) else 99) in result + 0
//
// Pass 1:
//   - If condition: flag (no change, cond' = cond)
//   - Then branch: let a=2+3 → a=5 (beta-reduced), let b=5+1 → b=6 (beta-reduced), Return 6
//   - Else branch: 99 (no change)
//   - With ||: changed = false || true || false = true
//   - With &&: changed = false && true && false = false (WRONG!)
//
// The outer Let sees bodyChanged from the If.
// If If reports false, the function reports changed=false, stopping early.
// This test verifies correct behavior when nested inside Let.
def testIfMultiPassSingleBranch(flag: Bool) : Int64 =
  if flag then
    let a = 2 + 3 in
    let b = a + 1 in
    b
  else
    99
testIfMultiPassSingleBranch(true) = 6
testIfMultiPassSingleBranch(false) = 99

// Nested If where outer depends on inner change flag
// The inner If has changes only in one branch
// The outer Let uses the If result
// Tests that change propagates: inner If → outer Let → function → more passes
def testNestedIfChangeFlag(outer: Bool, inner: Bool) : Int64 =
  let x = (if inner then
             let a = 3 + 4 in  // folds to 7, beta-reduced
             a
           else
             50) in
  if outer then x + 1 else x + 2
testNestedIfChangeFlag(true, true) = 8
testNestedIfChangeFlag(true, false) = 51
testNestedIfChangeFlag(false, true) = 9
testNestedIfChangeFlag(false, false) = 52

// ===================================================================
// Comparison Constant Folding (MIR Level)
// ===================================================================
// These tests verify that comparison operators are correctly folded
// when operands become constants through propagation.
// This specifically exercises the MIR_Optimize constant folding for Lte.

// Less-than-or-equal comparison with propagated constants
// The key is using values where <= and >= produce different results
let a = 2 in let b = 3 in (a <= b) = true
let a = 3 in let b = 2 in (a <= b) = false

// Boundary case: equal values (both <= and >= would be true)
let a = 5 in let b = 5 in (a <= b) = true

// More complex: comparison result used in further computation
let x = 1 in let y = 2 in if x <= y then 100 else 200 = 100
let x = 3 in let y = 2 in if x <= y then 100 else 200 = 200

// ===================================================================
// LICM Copy Propagation (MIR Level)
// ===================================================================
// These tests verify that the optimizer correctly handles copy propagation
// in loops (LICM). The buildCopyMapForLicm function tracks copies like
// Mov(dest, Register src) where dest <> src, enabling loop-invariant
// code motion to hoist computations that depend on copied values.

// Test with copy before loop-invariant computation in recursive function
// The copy 'alias = x' creates a Mov, and 'alias * alias' is loop-invariant
def licmCopy(x: Int64, n: Int64, acc: Int64) : Int64 =
  if n <= 0 then acc
  else
    let alias = x in
    let sq = alias * alias in
    licmCopy(x, n - 1, acc + sq)

licmCopy(3, 5, 0) = 45
licmCopy(4, 3, 0) = 48

// Chain of copies that LICM needs to resolve
def licmCopyChain(x: Int64, n: Int64, acc: Int64) : Int64 =
  if n <= 0 then acc
  else
    let a = x in
    let b = a in
    let c = b in
    let product = c * c in
    licmCopyChain(x, n - 1, acc + product)

licmCopyChain(2, 4, 0) = 16
licmCopyChain(5, 3, 0) = 75

// Copy used in comparison (loop condition optimization)
def licmCopyCmp(x: Int64, limit: Int64, n: Int64) : Int64 =
  if n <= 0 then 0
  else
    let xCopy = x in
    if xCopy > limit then n else licmCopyCmp(x, limit, n - 1)

licmCopyCmp(10, 5, 3) = 3
licmCopyCmp(3, 5, 3) = 0

// ===================================================================
// General Copy Propagation (MIR Level - buildCopyMap)
// ===================================================================
// These tests verify that the optimizer correctly handles copy propagation
// in the main optimization pass (not LICM). The buildCopyMap function tracks
// copies like Mov(dest, Register src) where dest <> src, enabling uses of
// dest to be replaced with src for further optimization.

// Basic register-to-register copy propagation
// Creates Mov(y, Register x) which should be tracked
// Then y should be replaced with x, enabling constant folding
def copyPropBasic(x: Int64) : Int64 =
  let y = x in
  let z = y in
  z + 1

copyPropBasic(10) = 11
copyPropBasic(-5) = -4

// Chain of copies that main copy propagation resolves
// Creates: a = param, b = a, c = b, result = c + 1
// Copy prop should resolve c -> b -> a -> param
def copyPropChain(input: Int64) : Int64 =
  let a = input in
  let b = a in
  let c = b in
  c + c

copyPropChain(7) = 14
copyPropChain(100) = 200

// Copy propagation across arithmetic operations
// The copy must be propagated correctly through expressions
def copyPropArith(x: Int64, y: Int64) : Int64 =
  let xCopy = x in
  let yCopy = y in
  (xCopy * yCopy) + (xCopy - yCopy)

copyPropArith(5, 3) = 17
copyPropArith(10, 2) = 28

// High register pressure with copies
// Creates many live values through copies, testing that copy propagation
// correctly reduces virtual register usage before register allocation
def copyPropPressure(x: Int64) : Int64 =
  let a = x in
  let b = a in
  let c = b in
  let d = c in
  let e = d in
  let f = e in
  let g = f in
  let h = g in
  let i = h in
  let j = i in
  // Use all the copies to ensure they're not dead-code eliminated
  a + b + c + d + e + f + g + h + i + j

copyPropPressure(1) = 10
copyPropPressure(5) = 50

// ===================================================================
// Copy Propagation enabling CSE (mutation #149 test)
// ===================================================================
// This test specifically exercises the buildCopyMap dest <> src check.
// When a register-to-register Mov is tracked, uses of dest can be
// replaced with src, which enables CSE to recognize common subexpressions.
//
// Without copy propagation:
//   y = x                    (Mov not tracked with mutation)
//   temp1 = y + z            (uses y)
//   temp2 = x + z            (uses x, looks different from temp1)
//   result = temp1 + temp2   (no CSE possible)
//
// With copy propagation:
//   y replaced with x everywhere
//   temp1 = x + z            (after propagation)
//   temp2 = x + z            (same as temp1!)
//   result = temp1 + temp1   (CSE eliminates temp2)
//
// The test verifies correctness, and should catch any issues
// from incorrect copy propagation behavior.

def copyPropEnablesCSE(x: Int64, z: Int64) : Int64 =
  let y = x in
  let temp1 = y + z in
  let temp2 = x + z in
  temp1 + temp2

copyPropEnablesCSE(10, 5) = 30
copyPropEnablesCSE(7, 3) = 20
copyPropEnablesCSE(-5, 2) = -6

// More complex copy propagation + CSE interaction
def copyPropCSEComplex(a: Int64, b: Int64) : Int64 =
  let aCopy = a in
  let bCopy = b in
  let sum1 = aCopy + bCopy in
  let sum2 = a + b in
  let sum3 = aCopy + b in
  sum1 + sum2 + sum3

copyPropCSEComplex(10, 20) = 90
copyPropCSEComplex(5, 5) = 30

// ===================================================================
// Phi Node Copy Propagation (mutation #150 test)
// ===================================================================
// This test exercises buildCopyMap's handling of Phi nodes where all
// sources are the same register. The code at line 603 checks:
//   if dest <> firstSrc then Map.add dest (Register firstSrc) m
//
// If the mutation changes <> to =, only self-copy phis would be tracked,
// which breaks propagation for useful phi copies like:
//   y = phi(a, a) where y != a
//
// The test creates a phi node by having both branches of an if-else
// return the same variable. The phi merges these identical sources.

// Simple phi with identical sources from both branches
// Creates: y = phi(x, x) from both if-branches returning x
// The optimizer should propagate y -> x, enabling y + y -> x + x
def phiCopyProp(flag: Bool, x: Int64) : Int64 =
  let y = if flag then x else x in
  y + y

phiCopyProp(true, 10) = 20
phiCopyProp(false, 7) = 14

// Phi copy propagation enabling further optimization
// After phi propagation, uses of 'result' become uses of 'input'
def phiCopyPropChain(flag: Bool, input: Int64) : Int64 =
  let a = input in
  let result = if flag then a else a in
  result * 2 + input

phiCopyPropChain(true, 5) = 15
phiCopyPropChain(false, 8) = 24

// Nested branches creating phi with same sources
// The inner if-else creates a phi, then outer expression uses it
def phiCopyPropNested(outer: Bool, inner: Bool, x: Int64) : Int64 =
  let value = x + 1 in
  let y = if inner then value else value in
  if outer then y + value else y - value

phiCopyPropNested(true, true, 10) = 22
phiCopyPropNested(true, false, 10) = 22
phiCopyPropNested(false, true, 10) = 0
phiCopyPropNested(false, false, 10) = 0

// ===================================================================
// Int64Const Copy Propagation with existing map entries (mutation #152)
// ===================================================================
// This test exercises the buildCopyMap function at line 586, specifically
// testing the case where Int64Const propagation should respect existing
// map entries and type constraints.
//
// The mutation changes && to || in the condition:
//   if Set.contains dest phiDests || Map.containsKey dest m || not isIntOrBoolType then m
//
// If && were used instead of ||, the behavior would change for cases where
// dest is already in the map but the type IS int/bool (isIntOrBoolType=true).
// With &&: (already in map) && (not int/bool) = false when type is int, so would ADD
// With ||: (already in map) = true, so correctly SKIPs adding
//
// This test creates a scenario where a variable is used in multiple contexts
// to ensure constant propagation correctly tracks and optimizes Int64 constants.

// Multiple constant assignments that should all propagate correctly
def multiConstProp(x: Int64) : Int64 =
  let a = 10 in
  let b = 20 in
  let c = a + b in  // c = 30 after constant folding
  x + c

multiConstProp(5) = 35
multiConstProp(0) = 30
multiConstProp(-10) = 20

// Chain of constant propagation with conditionals
// Tests that Int64Const propagation works correctly through branches
def constPropThroughBranch(flag: Bool, x: Int64) : Int64 =
  let base = 100 in
  let result = if flag then
    let adjusted = base + x in  // 100 + x
    adjusted
  else
    let adjusted = base - x in  // 100 - x
    adjusted
  in
  result + base  // result + 100

constPropThroughBranch(true, 5) = 205
constPropThroughBranch(false, 5) = 195
constPropThroughBranch(true, 0) = 200
constPropThroughBranch(false, 0) = 200

// Test that constant propagation respects phi destinations
// When a variable is assigned in multiple branches, it becomes a phi dest
// and should NOT be propagated to avoid incorrect optimizations
def constPropWithPhi(flag: Bool) : Int64 =
  let x = if flag then 42 else 99 in
  let y = x + 1 in  // x is phi dest, y should use x (not constant)
  y

constPropWithPhi(true) = 43
constPropWithPhi(false) = 100

// ===================================================================
// Domination Check in Loop Detection (mutation #153 test)
// ===================================================================
// This test exercises the dominates function which is used to identify
// natural loops for LICM. The function at line 210 has:
//   node = entry || Map.containsKey node idoms
//
// If || becomes &&, the entry block would fail to dominate other blocks,
// breaking loop detection. This test creates scenarios where domination
// must work correctly for the optimizer to behave properly.
//
// While LICM is an optimization, incorrect domination could affect
// which code gets hoisted. We test that loop-invariant code is
// correctly handled regardless of entry block domination.

// Simple recursive loop with invariant computation
// The invariant 'base * base' should produce correct results
// whether or not it gets hoisted by LICM
def dominationLoop(base: Int64, n: Int64, acc: Int64) : Int64 =
  if n <= 0 then acc
  else
    let invariant = base * base in
    dominationLoop(base, n - 1, acc + invariant)

dominationLoop(3, 4, 0) = 36
dominationLoop(5, 3, 0) = 75
dominationLoop(2, 10, 0) = 40

// Nested invariant computations that rely on domination
// The optimizer should correctly handle invariants at different levels
def nestedDominationLoop(a: Int64, b: Int64, n: Int64, acc: Int64) : Int64 =
  if n <= 0 then acc
  else
    let outerInvariant = a + b in
    let innerInvariant = outerInvariant * 2 in
    nestedDominationLoop(a, b, n - 1, acc + innerInvariant)

nestedDominationLoop(3, 4, 5, 0) = 70
nestedDominationLoop(10, 5, 3, 0) = 90

// Test where domination affects which blocks are in the loop body
// This creates a control flow where entry domination matters
def conditionalDominationLoop(x: Int64, flag: Bool, n: Int64) : Int64 =
  if n <= 0 then 0
  else
    let value = if flag then x * x else x + x in
    value + conditionalDominationLoop(x, flag, n - 1)

conditionalDominationLoop(3, true, 4) = 36
conditionalDominationLoop(3, false, 4) = 24

// ===================================================================
// LICM buildCopyMapForLicm Phi Destination Check (mutation #154)
// ===================================================================
// This test exercises the || operator in buildCopyMapForLicm at line 305:
//   if Set.contains dest phiDests || Map.containsKey dest mapAcc then mapAcc
//
// If || becomes &&, phi destinations would be incorrectly added to the
// copy map when they're not already in the map. This could cause LICM
// to incorrectly resolve operands, treating phi results as simple copies.
//
// The test creates a scenario with:
// 1. A loop (recursive function)
// 2. A conditional inside the loop creating a phi node
// 3. A copy of the phi result used in subsequent computation
// 4. LICM analysis of the copied value
//
// With the mutation, the copy map might incorrectly track the phi result,
// leading to wrong operand resolution during invariant detection.

// Test with phi result used in loop-invariant computation
// The 'selected' variable is a phi dest (from if-then-else)
// The copy 'copy = selected' creates a Mov
// LICM should correctly handle this without treating selected as a simple copy
def licmPhiDestCheck(x: Int64, y: Int64, flag: Bool, n: Int64, acc: Int64) : Int64 =
  if n <= 0 then acc
  else
    // 'selected' is a phi destination (comes from different branches)
    let selected = if flag then x else y in
    // Create a copy of the phi result
    let copy = selected in
    // Use the copy in a computation that LICM might analyze
    let result = copy * copy in
    licmPhiDestCheck(x, y, flag, n - 1, acc + result)

// When flag is true: selected = x = 3, result = 9, sum over 5 iterations = 45
licmPhiDestCheck(3, 7, true, 5, 0) = 45
// When flag is false: selected = y = 7, result = 49, sum over 5 iterations = 245
licmPhiDestCheck(3, 7, false, 5, 0) = 245
// Mixed values to ensure correct behavior
licmPhiDestCheck(2, 5, true, 4, 0) = 16
licmPhiDestCheck(2, 5, false, 4, 0) = 100

// More complex: nested conditionals with multiple phi nodes
// This creates multiple phi destinations that copy propagation must respect
def licmNestedPhiDest(a: Int64, b: Int64, c: Int64, f1: Bool, f2: Bool, n: Int64) : Int64 =
  if n <= 0 then 0
  else
    // First phi: p1 = phi(a, b)
    let p1 = if f1 then a else b in
    // Second phi: p2 = phi(c, p1)
    let p2 = if f2 then c else p1 in
    // Copies of phi results
    let copy1 = p1 in
    let copy2 = p2 in
    // Computation using both
    let sum = copy1 + copy2 in
    sum + licmNestedPhiDest(a, b, c, f1, f2, n - 1)

// f1=true: p1=a=1, f2=true: p2=c=3, sum=1+3=4, 3 iters = 12
licmNestedPhiDest(1, 2, 3, true, true, 3) = 12
// f1=true: p1=a=1, f2=false: p2=p1=1, sum=1+1=2, 3 iters = 6
licmNestedPhiDest(1, 2, 3, true, false, 3) = 6
// f1=false: p1=b=2, f2=true: p2=c=3, sum=2+3=5, 3 iters = 15
licmNestedPhiDest(1, 2, 3, false, true, 3) = 15
// f1=false: p1=b=2, f2=false: p2=p1=2, sum=2+2=4, 3 iters = 12
licmNestedPhiDest(1, 2, 3, false, false, 3) = 12

// ===================================================================
// LICM Phi Invariant Detection - Outside Source Check (mutation #155)
// ===================================================================
// This test exercises the || operator in findInvariantPhis at line 407:
//   not (Set.contains vreg loopDefs) || Map.containsKey vreg acc'
//
// The outsideInvariant check determines if a phi's outside source is
// loop-invariant. A register is invariant if:
//   - It's NOT defined in the loop (not in loopDefs), OR
//   - It's already marked invariant (in acc')
//
// If || becomes &&, BOTH conditions would need to be true:
//   - The register must NOT be in loopDefs AND must be in acc'
//   - This breaks the first iteration where acc' is empty but valid
//     outside sources exist (defined before the loop)
//
// The test creates:
// 1. A recursive function (the "loop")
// 2. A value computed BEFORE entering the recursive pattern
// 3. A conditional inside the loop that creates a phi
// 4. The phi's outside source is the precomputed value
// 5. On first analysis pass, acc' is empty but the source IS invariant
//
// With ||: precomputed value is correctly identified as invariant
// With &&: precomputed value fails check (not in acc' yet), phi not invariant

// Test: outside source from before the loop, not yet in invariant map
// The 'precomputed' value is computed before the recursive calls
// Inside the loop, a conditional creates a phi with precomputed as outside source
def licmPhiOutsideSource(x: Int64, flag: Bool, n: Int64, acc: Int64) : Int64 =
  // precomputed is defined BEFORE the loop (recursive calls)
  let precomputed = x * x in
  if n <= 0 then acc
  else
    // This conditional creates a phi: value = phi(precomputed, precomputed)
    // The sources from outside the loop come from precomputed
    // With correct ||: precomputed IS invariant (not in loopDefs)
    // With && mutation: precomputed wrongly fails (not in acc' on first pass)
    let value = if flag then precomputed else precomputed in
    licmPhiOutsideSource(x, flag, n - 1, acc + value)

// x=3: precomputed = 9, each iteration adds 9, 5 iterations = 45
licmPhiOutsideSource(3, true, 5, 0) = 45
licmPhiOutsideSource(3, false, 5, 0) = 45

// x=4: precomputed = 16, 4 iterations = 64
licmPhiOutsideSource(4, true, 4, 0) = 64
licmPhiOutsideSource(4, false, 4, 0) = 64

// More complex: multiple precomputed values used in phi
// Tests that LICM correctly handles multiple outside sources
def licmPhiMultiOutside(a: Int64, b: Int64, flag: Bool, n: Int64) : Int64 =
  let pre1 = a * a in
  let pre2 = b * b in
  if n <= 0 then 0
  else
    // value depends on flag, but both branches use precomputed values
    let value = if flag then pre1 else pre2 in
    value + licmPhiMultiOutside(a, b, flag, n - 1)

// flag=true: uses pre1 = 2*2 = 4, 3 iterations = 12
licmPhiMultiOutside(2, 3, true, 3) = 12
// flag=false: uses pre2 = 3*3 = 9, 3 iterations = 27
licmPhiMultiOutside(2, 3, false, 3) = 27

// Chain of precomputed values where LICM must resolve correctly
def licmPhiChainedOutside(x: Int64, flag: Bool, n: Int64) : Int64 =
  let step1 = x + 1 in
  let step2 = step1 * 2 in
  let step3 = step2 + 3 in
  if n <= 0 then 0
  else
    // phi with chained precomputed source
    let value = if flag then step3 else step3 in
    value + licmPhiChainedOutside(x, flag, n - 1)

// x=5: step1=6, step2=12, step3=15, 4 iterations = 60
licmPhiChainedOutside(5, true, 4) = 60
licmPhiChainedOutside(5, false, 4) = 60

// ===================================================================
// LICM Hoistable Instruction Uses Check (mutation #156)
// ===================================================================
// This test exercises the || operator in findHoistable at line 461:
//   not (Set.contains vreg loopDefs) || Set.contains vreg invs
//
// The usesInvariant check determines if an instruction can be hoisted.
// An instruction is hoistable if ALL its used registers are invariant:
//   - The register is NOT defined in the loop (not in loopDefs), OR
//   - The register is already marked as invariant (in invs)
//
// If || becomes &&, BOTH conditions would need to be true:
//   - The register must NOT be in loopDefs AND must be in invs
//   - This breaks hoisting for instructions that use values defined
//     outside the loop, since those won't be in invs initially
//
// The test creates:
// 1. A recursive function (the "loop")
// 2. A value computed BEFORE the loop
// 3. An arithmetic instruction inside the loop using that value
// 4. LICM should recognize the instruction as hoistable
//
// With ||: instruction using outer value is correctly hoistable
// With &&: instruction fails check (outer value not in invs), not hoisted

// Test: hoistable instruction using value defined outside loop
// The 'base' value is defined BEFORE the recursive calls
// Inside the loop, 'sq = base * base' uses only 'base' which is loop-invariant
// With correct ||: base is invariant (not in loopDefs), so sq is hoistable
// With && mutation: base wrongly fails (not in invs on first pass)
def licmHoistableUses(base: Int64, n: Int64, acc: Int64) : Int64 =
  if n <= 0 then acc
  else
    // This computation uses only 'base' which is defined outside the loop
    // LICM should detect this as hoistable since base is loop-invariant
    let sq = base * base in
    licmHoistableUses(base, n - 1, acc + sq)

// base=4: sq = 16, each iteration adds 16, 5 iterations = 80
licmHoistableUses(4, 5, 0) = 80
// base=3: sq = 9, 6 iterations = 54
licmHoistableUses(3, 6, 0) = 54

// More complex: multiple invariant uses in one instruction
// Tests that all operands of a binary operation are checked
def licmHoistableMultiUses(a: Int64, b: Int64, n: Int64, acc: Int64) : Int64 =
  if n <= 0 then acc
  else
    // Both 'a' and 'b' are loop-invariant (defined outside)
    // The instruction 'prod = a * b' should be hoistable
    let prod = a * b in
    licmHoistableMultiUses(a, b, n - 1, acc + prod)

// a=3, b=4: prod = 12, 5 iterations = 60
licmHoistableMultiUses(3, 4, 5, 0) = 60
// a=5, b=7: prod = 35, 3 iterations = 105
licmHoistableMultiUses(5, 7, 3, 0) = 105

// Chain of hoistable instructions where each depends on previous
// Tests that LICM correctly propagates invariant status through invs
def licmHoistableChain(x: Int64, n: Int64, acc: Int64) : Int64 =
  if n <= 0 then acc
  else
    // step1 uses only x (invariant), so step1 is hoistable
    // step2 uses step1 (becomes invariant after hoisting step1)
    // step3 uses step2 (becomes invariant after hoisting step2)
    // All three should be hoisted with iterative LICM
    let step1 = x + 1 in
    let step2 = step1 * 2 in
    let step3 = step2 + 5 in
    licmHoistableChain(x, n - 1, acc + step3)

// x=2: step1=3, step2=6, step3=11, 4 iterations = 44
licmHoistableChain(2, 4, 0) = 44
// x=10: step1=11, step2=22, step3=27, 3 iterations = 81
licmHoistableChain(10, 3, 0) = 81

// ===================================================================
// LICM Change Flag Aggregation Across Blocks (mutation #157)
// ===================================================================
// This test exercises the || operator in findHoistable at line 475:
//   (invAcc', mapAcc', chAcc || blockChanged)
//
// The change flag aggregates across multiple basic blocks in the loop.
// With ||: if ANY block has changes, the pass reports changed=true
// With &&: ALL blocks must have changes for changed=true
//
// If || becomes &&, then:
// - Block A has hoistable code (blockChanged=true)
// - Block B has no hoistable code (blockChanged=false)
// - With ||: true || false = true (correct, continue iterating)
// - With &&: true && false = false (WRONG, stops early)
//
// The test creates a loop with multiple blocks via conditionals:
// 1. Some blocks have hoistable code
// 2. Other blocks have non-hoistable code (or no computation)
// 3. A subsequent pass depends on the first pass's results
//
// With the mutation, the optimizer stops after first pass even when
// more hoisting is possible, leading to less optimized but still
// correct code. To catch this, we need a scenario where early stopping
// causes observable behavior change.

// Test: multiple blocks in loop, only some have hoistable code
// The conditional creates multiple basic blocks in the CFG
// The then-branch has hoistable code, the else-branch has runtime-dependent code
def licmBlockChangeProp(x: Int64, flag: Bool, n: Int64, acc: Int64) : Int64 =
  if n <= 0 then acc
  else
    let result = if flag then
      // This block has hoistable code: x * x is loop-invariant
      let sq = x * x in
      sq
    else
      // This block has no hoistable code: n is loop-variant
      n * 2
    in
    licmBlockChangeProp(x, flag, n - 1, acc + result)

// flag=true: uses sq = x*x = 9, each of 4 iterations adds 9 = 36
licmBlockChangeProp(3, true, 4, 0) = 36
// flag=false: uses n*2 for n=4,3,2,1 = 8+6+4+2 = 20
licmBlockChangeProp(3, false, 4, 0) = 20

// More complex: chain across blocks where hoisting in one enables another
def licmBlockChainHoist(a: Int64, b: Int64, flag: Bool, n: Int64) : Int64 =
  if n <= 0 then 0
  else
    // First block: hoistable computation
    let pre = a + b in
    let result = if flag then
      // This branch uses 'pre' and computes further hoistable value
      let doubled = pre * 2 in
      doubled
    else
      // This branch doesn't have additional hoisting
      pre
    in
    result + licmBlockChainHoist(a, b, flag, n - 1)

// flag=true: pre=3+4=7, doubled=14, 3 iterations = 42
licmBlockChainHoist(3, 4, true, 3) = 42
// flag=false: pre=3+4=7, 3 iterations = 21
licmBlockChainHoist(3, 4, false, 3) = 21

// ===================================================================
// DCE Change Flag Aggregation Across Blocks (mutation #158)
// ===================================================================
// This test exercises the || operator in eliminateDeadCode at line 544:
//   (Map.add label block' acc, ch || instrChanged)
//
// The change flag aggregates across multiple basic blocks in the CFG.
// With ||: if ANY block has dead code removed, the pass reports changed=true
// With &&: ALL blocks must have dead code removed for changed=true
//
// If || becomes &&, then:
// - Block A has dead code (instrChanged=true after removal)
// - Block B has no dead code (instrChanged=false)
// - With ||: ch = true || false = true (correct, enables more optimization passes)
// - With &&: ch = true && false = false (WRONG, optimization stops early)
//
// Actually with &&:
// - Start: ch = false
// - After Block A: ch = false && true = false
// - After Block B: ch = false && false = false
// - Result: always false regardless of actual changes!
//
// The test creates a function with:
// 1. Dead code in some blocks (unused let bindings)
// 2. Live code in other blocks
// 3. A chain of optimizations where DCE enables further constant folding
//
// The DCE pass removing dead code enables subsequent passes to see simpler
// code patterns and optimize further. If DCE reports no changes (with mutation),
// the optimizer might stop early, leaving less optimized code.

// Test: dead code in one branch, live code in another
// The 'unused' variable is dead code in the then-branch
// The else-branch has no dead code
// DCE should remove 'unused' and report changed=true
// With mutation: DCE reports false, but still removes the code (just doesn't iterate more)
def dceMultiBlock(flag: Bool, x: Int64) : Int64 =
  if flag then
    let unused = x * x in  // dead code - unused
    let result = x + 1 in
    result
  else
    x + 2

dceMultiBlock(true, 5) = 6
dceMultiBlock(false, 5) = 7
dceMultiBlock(true, 10) = 11
dceMultiBlock(false, 10) = 12

// More complex: chain of dead code removal enabling constant propagation
// Pass 1: DCE removes 'dead1' (unused)
// This simplifies the code, potentially enabling more optimizations
// If DCE's change flag is wrong, fewer passes run
def dceChainOptimization(flag: Bool, x: Int64) : Int64 =
  if flag then
    let dead1 = x * x * x in  // unused - dead code
    let dead2 = dead1 + 1 in  // depends on dead1, also becomes dead
    let live = x + 10 in
    live
  else
    let alsoLive = x + 20 in
    alsoLive

dceChainOptimization(true, 3) = 13
dceChainOptimization(false, 3) = 23
dceChainOptimization(true, 7) = 17
dceChainOptimization(false, 7) = 27

// Test where DCE in multiple blocks should all report changes
// Every branch has dead code, but with && mutation this would still fail
// because ch starts as false and && with anything keeps it false
def dceAllBlocksHaveDead(choice: Int64) : Int64 =
  if choice == 1 then
    let dead = 100 in  // unused
    1
  else if choice == 2 then
    let dead = 200 in  // unused
    2
  else
    let dead = 300 in  // unused
    3

dceAllBlocksHaveDead(1) = 1
dceAllBlocksHaveDead(2) = 2
dceAllBlocksHaveDead(3) = 3
dceAllBlocksHaveDead(0) = 3

// Recursive function where DCE iterates
// Each recursive call creates dead code patterns
// The optimizer should iterate until no more dead code exists
def dceRecursive(n: Int64, acc: Int64) : Int64 =
  if n <= 0 then acc
  else
    let dead = n * n in  // unused - dead code
    let next = n - 1 in
    dceRecursive(next, acc + n)

// Sum of 1..5 = 15
dceRecursive(5, 0) = 15
dceRecursive(10, 0) = 55
dceRecursive(1, 0) = 1
dceRecursive(0, 0) = 0

// ===================================================================
// Phi Destination in Copy Map (mutation #159 test)
// ===================================================================
// This test exercises the || operator in buildCopyMap at line 574:
//   if Set.contains dest phiDests || Map.containsKey dest m then m
//
// This checks whether to skip adding a register-to-register Mov to the copy map.
// We skip if:
//   - The destination is a phi destination (from a conditional), OR
//   - The destination is already tracked in the map
//
// If || becomes &&, the condition would require BOTH to be true:
//   - With ||: skip if dest is phi dest OR already in map (correct)
//   - With &&: skip only if dest is BOTH phi dest AND in map (wrong!)
//
// The bug: phi destinations would be added to the copy map when they shouldn't be.
// This causes incorrect copy propagation - the phi result gets replaced with one
// of its sources, losing the conditional nature of the value.
//
// The test creates a phi destination (from if-then-else) and then creates a
// register-to-register copy of it. With the mutation, the copy map would
// incorrectly track the phi result, leading to wrong substitution.

// Test: phi destination should not be tracked as a simple copy source
// The 'selected' variable is a phi destination (from if-then-else)
// It represents different values depending on the flag
// The copy 'alias = selected' creates a Mov
// With correct ||: selected is phi dest, so not added to copy map
// With && mutation: selected added to copy map (wrongly), then propagated
def phiDestCopyMap(flag: Bool, a: Int64, b: Int64) : Int64 =
  // 'selected' is a phi destination - its value depends on flag
  let selected = if flag then a else b in
  // Create a copy of the phi result
  let alias = selected in
  // Use both to ensure they should have same value
  selected + alias

// When flag=true: selected=a=10, alias=selected=10, result = 10+10 = 20
phiDestCopyMap(true, 10, 5) = 20
// When flag=false: selected=b=5, alias=selected=5, result = 5+5 = 10
phiDestCopyMap(false, 10, 5) = 10

// More complex: phi dest used in arithmetic before copy
def phiDestCopyArith(flag: Bool, x: Int64, y: Int64) : Int64 =
  let chosen = if flag then x * 2 else y * 3 in
  let copy = chosen in
  chosen - copy  // Should always be 0

// Both branches should give 0
phiDestCopyArith(true, 5, 10) = 0
phiDestCopyArith(false, 5, 10) = 0

// Nested conditionals creating multiple phi destinations
// Tests that all phi destinations are correctly excluded from copy map
def nestedPhiDestCopy(f1: Bool, f2: Bool, a: Int64, b: Int64, c: Int64) : Int64 =
  let p1 = if f1 then a else b in
  let p2 = if f2 then p1 else c in
  let copy1 = p1 in
  let copy2 = p2 in
  (p1 + copy1) + (p2 + copy2)

// f1=true: p1=a=1, f2=true: p2=p1=1, result = (1+1) + (1+1) = 4
nestedPhiDestCopy(true, true, 1, 2, 3) = 4
// f1=true: p1=a=1, f2=false: p2=c=3, result = (1+1) + (3+3) = 8
nestedPhiDestCopy(true, false, 1, 2, 3) = 8
// f1=false: p1=b=2, f2=true: p2=p1=2, result = (2+2) + (2+2) = 8
nestedPhiDestCopy(false, true, 1, 2, 3) = 8
// f1=false: p1=b=2, f2=false: p2=c=3, result = (2+2) + (3+3) = 10
nestedPhiDestCopy(false, false, 1, 2, 3) = 10

// ===================================================================
// Constant Branch Simplification Change Flag (mutation #160)
// ===================================================================
// This test exercises the || operator in simplifyConstantBranches at line 793:
//   let changed' = ch || term' <> block.Terminator
//
// The change flag aggregates across multiple basic blocks in the CFG.
// With ||: if ANY block has a constant branch simplified, changed=true
// With &&: ALL blocks must have changes for changed=true (WRONG!)
//
// The simplifyConstantBranches function converts:
//   Branch(BoolConst true, trueLabel, falseLabel) -> Jump trueLabel
//   Branch(BoolConst false, trueLabel, falseLabel) -> Jump falseLabel
//
// If || becomes &&, the accumulator starts with ch=false and:
// - After first block with change: ch = false && true = false
// - After block without change: ch = false && false = false
// - Result: always false, even when changes occurred!
//
// This causes the optimizer to stop iterating early. The test creates:
// 1. A function with multiple blocks (via conditionals)
// 2. One block has a constant condition (if true then ...) that gets simplified
// 3. Other blocks have runtime conditions (no simplification)
// 4. Multi-pass optimization depends on the change flag

// Test: constant branch in one block, runtime condition in another
// The inner 'if true then 10 else 20' should simplify to just 10
// The outer condition uses a runtime parameter (flag)
// With ||: change flag is true, enabling further passes
// With && mutation: change flag incorrectly becomes false
def constantBranchMultiBlock(flag: Bool, x: Int64) : Int64 =
  if flag then
    // This block has a constant branch: 'if true then 10 else 20' -> 10
    let inner = if true then 10 else 20 in
    x + inner
  else
    // This block has a runtime condition - no constant branch to simplify
    x * 2

// flag=true: inner = 10, result = x + 10 = 15
constantBranchMultiBlock(true, 5) = 15
// flag=false: result = x * 2 = 10
constantBranchMultiBlock(false, 5) = 10

// More complex: chain of constant branches that require multiple passes
// First pass simplifies outer constant, second pass can see more patterns
def constantBranchChain(flag: Bool) : Int64 =
  if flag then
    // Multiple constant conditions in sequence
    let a = if true then 1 else 99 in
    let b = if false then 99 else 2 in
    a + b
  else
    // Runtime path - no constant branches
    42

// flag=true: a=1, b=2, result=3
constantBranchChain(true) = 3
// flag=false: result=42
constantBranchChain(false) = 42

// Test that relies on constant branch enabling dead code elimination
// The constant branch simplifies 'if true then x else y' to just x
// This makes 'y' potentially dead if not used elsewhere
def constantBranchEnablesDCE(flag: Bool, x: Int64, y: Int64) : Int64 =
  if flag then
    // Constant branch chooses x, making the computation for y unused
    let result = if true then x * 2 else y * 3 in
    result
  else
    // Both are used here, so DCE cannot remove either
    x + y

// flag=true: uses x*2 = 20, the y*3 computation can be DCE'd
constantBranchEnablesDCE(true, 10, 5) = 20
// flag=false: uses x+y = 15
constantBranchEnablesDCE(false, 10, 5) = 15

// Nested constant branches in different blocks
// Each level has a constant condition that simplifies
def nestedConstantBranches(flag: Bool) : Int64 =
  if flag then
    // Outer constant branch
    if true then
      // Inner constant branch
      if false then 100 else 200
    else
      300
  else
    // Runtime path
    400

// flag=true: outer true -> inner (false branch) -> 200
nestedConstantBranches(true) = 200
nestedConstantBranches(false) = 400
