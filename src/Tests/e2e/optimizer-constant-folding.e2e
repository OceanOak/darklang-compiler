// Optimizer Constant Folding Tests
//
// These tests verify that the optimizer correctly folds constants.
// This exercises:
// - Unary operation folding (negation, not)
// - Constant propagation through variables
// - Combined optimizations

// ===================================================================
// Unary Operation Folding
// ===================================================================
// Test that negation and not are folded correctly

// Negation through variables (can't be folded at parse time)
let x = 5 in -x = -5
let x = -10 in -x = 10
let x = 0 in -x = 0

// Negation of expressions
let x = 3 in let y = 2 in -(x + y) = -5
let x = 10 in let y = 3 in -(x - y) = -7

// Boolean not through variables
let b = true in !b = false
let b = false in !b = true

// Nested not
let b = true in !!b = true
let b = false in !!b = false

// ===================================================================
// Constant Propagation
// ===================================================================
// Verify constants propagate through multiple let bindings

// Simple propagation
let x = 10 in x = 10
let x = 10 in let y = x in y = 10
let x = 10 in let y = x in let z = y in z = 10

// Propagation with arithmetic
let x = 5 in let y = x + 3 in y = 8
let x = 10 in let y = x * 2 in let z = y + 1 in z = 21

// ===================================================================
// Combined Optimizations
// ===================================================================
// Test that multiple optimizations work together

// Const fold + DCE
let unused = 1 + 2 in let x = 5 in x + 1 = 6

// Const prop + const fold
let a = 3 in let b = 4 in a * b = 12
let a = 10 in let b = a + 5 in let c = b * 2 in c = 30

// Negation + const prop + const fold
let x = 5 in let y = -x in let z = y + 10 in z = 5

// ===================================================================
// Multi-pass Optimization (requires multiple optimizer iterations)
// ===================================================================
// These tests require the optimizer to run multiple passes to fully optimize.
// Each pass enables further optimizations in subsequent passes.

// Chain of propagation and folding requiring multiple passes
// Pass 1: propagate a=2 into b=a+1, fold to b=3
// Pass 2: propagate b=3 into c=b+2, fold to c=5
// Pass 3: propagate c=5 into d=c+3, fold to d=8
// Pass 4: propagate d=8 into result
let a = 2 in let b = a + 1 in let c = b + 2 in let d = c + 3 in d = 8

// ===================================================================
// Strength Reduction (power-of-2 optimizations)
// ===================================================================
// These tests verify that multiplication/division/modulo by powers of 2
// are correctly optimized to shift/bitwise operations.
//
// IMPORTANT: The modulo optimization (x % n -> x & (n-1)) changes semantics
// for negative dividends. For signed integers:
//   - x % n gives result with sign of x (e.g., -7 % 4 = -3)
//   - x & (n-1) is always non-negative (e.g., -7 & 3 = 1)
// The optimizer applies this transformation, so we test the optimized behavior.
//
// NOTE: We use function parameters to prevent constant propagation from
// replacing the variable with its constant value before strength reduction runs.

// Modulo by power of 2 with negative dividend (tests tryLog2 boundary check)
// Without optimization: -7 % 2 = -1, but with optimization: -7 & 1 = 1
def mod2(x: Int64) : Int64 = x % 2 mod2(-7) = 1

// ===================================================================
// Return Statement Constant Propagation
// ===================================================================
// These tests verify that the optimizer correctly tracks changes when
// constant propagation occurs in Return statements. This exercises the
// optimizeAExpr Return case at line 335 (atom' <> atom comparison).

// Simple return with propagated constant
// The optimizer should propagate x=42 into the Return(x) -> Return(42)
let x = 42 in x = 42

// Return propagation through if-else branches (tests changed flag propagation)
// Both branches have Return statements that need constant propagation
def branchReturn(cond: Bool) : Int64 =
  let x = 100 in
    if cond then x else x + 1
branchReturn(true) = 100
branchReturn(false) = 101

// Chain of propagations where final return uses propagated value
// Tests that multiple optimization passes work correctly
let a = 1 in let b = a + 1 in let c = b + 1 in let d = c + 1 in let e = d + 1 in e = 5
