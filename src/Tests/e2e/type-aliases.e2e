// Type alias and sum type edge case tests
// Tests the parser's handling of single-variant sum types without the | syntax

// Test that type Unit2 = Unit2 works as a single-variant sum type
// This should work because the variant name matches the type name (line 902 in Parser.fs)
type Unit2 = Unit2 match Unit2 with | Unit2 -> 42 = 42

// Verify that primitive type names as type aliases work correctly
// type Foo = UInt64 should create a type alias, not a sum type
// This tests the primitive type guards in parseTypeDef (lines 909-911)
// Note: The backwards-compat single-variant sum type code (lines 907-914) requires
// remaining = [], but TEOF is always in remaining, making that code unreachable.
// However, primitive types are handled earlier by parseTypeBase, so UInt64 becomes
// TUInt64, not TRecord("UInt64", []), bypassing those guards entirely.
def testU64(x: UInt64): UInt64 = x + 1UL
testU64(41UL) = 42

// Verify that Bool as a type alias target works correctly
// type MyBool = Bool should create a type alias, not a sum type
// This tests the primitive type guard for "Bool" in parseTypeDef (line 911)
// Note: Like UInt64 above, Bool is parsed as TBool by parseTypeBase (line 506),
// not TRecord("Bool", []), so the guard at line 911 is unreachable.
type BoolAlias2 = Bool
def useBoolAlias(b: Bool): Int64 = if b then 1 else 0
useBoolAlias(true) = 1
useBoolAlias(false) = 0

// =====================================================
// Parameterized Type Aliases (kills mutation #118)
// =====================================================
// Tests resolveAliasType's handling of generic type aliases where the
// number of type parameters must match the number of type arguments.
// Mutation #118 changes <> to = in the arity check, which would cause
// type aliases with matching arity to NOT be resolved (substitution skipped).

// Define a generic type alias for List<t> - this is a parameterized type alias
type MyList118<t> = List<t>

// Use the alias with a concrete type argument
// If the mutation is applied, the alias won't resolve because substitution is skipped
// when typeParams.Length = args.Length (should be <>, mutation makes it =)
def sumMyList(xs: MyList118<Int64>): Int64 = match xs with | [] -> 0 | [x, ...rest] -> x + sumMyList(rest)
sumMyList([10, 20, 12]) = 42
