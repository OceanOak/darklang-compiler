// LIR Peephole Optimization Tests
//
// These tests exercise the LIR peephole optimizer, specifically:
// - TBZ/TBNZ fusion (AND with power-of-2 mask + branch)
// - Multiply-by-constant strength reduction
// - Loop invariant code motion (LICM)
// - Bit position calculations

// ===================================================================
// Bit Position Tests (exercises bitPosition function in LIR_Peephole)
// ===================================================================
// The bitPosition function calculates log2 of power-of-2 values
// and is used by TBZ/TBNZ optimization to determine which bit to test.
// These tests verify correct bit extraction at various positions.

// Test bit 0 extraction (power-of-2 mask = 1)
def testBit0(x: Int64) : Int64 =
  if (x & 1) == 0 then 0 else 1
testBit0(0) = 0
testBit0(1) = 1
testBit0(2) = 0
testBit0(3) = 1
testBit0(254) = 0
testBit0(255) = 1

// Test bit 1 extraction (power-of-2 mask = 2)
def testBit1(x: Int64) : Int64 =
  if (x & 2) == 0 then 0 else 1
testBit1(0) = 0
testBit1(1) = 0
testBit1(2) = 1
testBit1(3) = 1
testBit1(4) = 0
testBit1(5) = 0
testBit1(6) = 1
testBit1(7) = 1

// Test bit 2 extraction (power-of-2 mask = 4)
def testBit2(x: Int64) : Int64 =
  if (x & 4) == 0 then 0 else 1
testBit2(0) = 0
testBit2(3) = 0
testBit2(4) = 1
testBit2(7) = 1
testBit2(8) = 0
testBit2(12) = 1

// Test bit 3 extraction (power-of-2 mask = 8)
def testBit3(x: Int64) : Int64 =
  if (x & 8) == 0 then 0 else 1
testBit3(0) = 0
testBit3(7) = 0
testBit3(8) = 1
testBit3(15) = 1
testBit3(16) = 0
testBit3(24) = 1

// Test bit 4 extraction (power-of-2 mask = 16)
def testBit4(x: Int64) : Int64 =
  if (x & 16) == 0 then 0 else 1
testBit4(0) = 0
testBit4(15) = 0
testBit4(16) = 1
testBit4(31) = 1
testBit4(32) = 0
testBit4(48) = 1

// Test higher bit positions
def testBit7(x: Int64) : Int64 =
  if (x & 128) == 0 then 0 else 1
testBit7(0) = 0
testBit7(127) = 0
testBit7(128) = 1
testBit7(255) = 1
testBit7(256) = 0

// Test bit 8 (mask = 256)
def testBit8(x: Int64) : Int64 =
  if (x & 256) == 0 then 0 else 1
testBit8(0) = 0
testBit8(255) = 0
testBit8(256) = 1
testBit8(511) = 1
testBit8(512) = 0

// ===================================================================
// Combined Bit Operations
// ===================================================================
// These test multiple bit positions in sequence, exercising the
// bit position calculation multiple times.

// Extract multiple bits and combine them
def extractBits(x: Int64) : Int64 =
  let b0 = if (x & 1) == 0 then 0 else 1 in
  let b1 = if (x & 2) == 0 then 0 else 2 in
  let b2 = if (x & 4) == 0 then 0 else 4 in
  b0 + b1 + b2

extractBits(0) = 0
extractBits(1) = 1
extractBits(2) = 2
extractBits(3) = 3
extractBits(4) = 4
extractBits(5) = 5
extractBits(6) = 6
extractBits(7) = 7

// ===================================================================
// LICM with Bit Operations
// ===================================================================
// These tests combine LICM with bit testing to exercise multiple
// optimization passes together.

def loopWithBitTest(mask: Int64, n: Int64, acc: Int64) : Int64 =
  if n <= 0 then acc
  else
    // Loop-invariant bit test on mask
    let hasBit = if (mask & 4) == 0 then 0 else 10 in
    loopWithBitTest(mask, n - 1, acc + hasBit)

// mask=4 has bit 2 set, so hasBit=10, 5 iterations = 50
loopWithBitTest(4, 5, 0) = 50
// mask=3 doesn't have bit 2 set, so hasBit=0, 5 iterations = 0
loopWithBitTest(3, 5, 0) = 0
// mask=7 has bit 2 set, so hasBit=10, 3 iterations = 30
loopWithBitTest(7, 3, 0) = 30
// mask=0 doesn't have bit 2 set
loopWithBitTest(0, 10, 0) = 0

// ===================================================================
// Multiply-by-Constant Strength Reduction Tests
// ===================================================================
// The LIR peephole optimizer converts multiplication by constants
// of the form (2^n - 1) or (2^n + 1) to shift + add/sub sequences.
// For (2^n - 1): x * n = (x << shift) - x
// For (2^n + 1): x * n = (x << shift) + x
//
// Mutation #175 tests: if the subtraction in (x << shift) - x
// were changed to addition, multiply by 7, 15, 31, 63 would be wrong.

// Multiply by 7 (2^3 - 1 = 8 - 1)
// Correct: x * 7 = (x << 3) - x = 8x - x = 7x
// If mutated to +: (x << 3) + x = 8x + x = 9x (WRONG)
def mulBy7(x: Int64) : Int64 = x * 7
mulBy7(1) = 7
mulBy7(2) = 14
mulBy7(3) = 21
mulBy7(10) = 70
mulBy7(100) = 700

// Multiply by 15 (2^4 - 1 = 16 - 1)
def mulBy15(x: Int64) : Int64 = x * 15
mulBy15(1) = 15
mulBy15(2) = 30
mulBy15(3) = 45
mulBy15(10) = 150

// Multiply by 31 (2^5 - 1 = 32 - 1)
def mulBy31(x: Int64) : Int64 = x * 31
mulBy31(1) = 31
mulBy31(2) = 62
mulBy31(3) = 93
mulBy31(10) = 310

// Multiply by 63 (2^6 - 1 = 64 - 1)
def mulBy63(x: Int64) : Int64 = x * 63
mulBy63(1) = 63
mulBy63(2) = 126
mulBy63(3) = 189
mulBy63(10) = 630

// ===================================================================
// isPowerOf2 Tests (Mutation #176)
// ===================================================================
// The isPowerOf2 function checks if a value is a power of 2 for use in
// TBZ/TBNZ optimization. It uses `n > 0L && (n &&& (n - 1L)) = 0L`.
//
// Mutation #176 changes `n > 0L` to `n < 0L`, which would cause isPowerOf2
// to return false for all positive values. This is an "equivalent mutant"
// because the TBZ/TBNZ optimization is purely a performance optimization -
// when isPowerOf2 returns false, the code falls back to AND + CBZ/CBNZ
// which produces identical results.
//
// The tests below exercise code paths that use isPowerOf2 through the
// TBZ/TBNZ optimization. While they pass with or without the optimization,
// they document the intended behavior.

// Power-of-2 mask values that trigger TBZ/TBNZ when isPowerOf2 works
// These masks are: 1, 2, 4, 8, 16, 32, 64, 128, 256, 512, 1024
def checkPowerOf2Mask1(x: Int64) : Int64 =
  if (x & 1) != 0 then 1 else 0
checkPowerOf2Mask1(0) = 0
checkPowerOf2Mask1(1) = 1
checkPowerOf2Mask1(2) = 0
checkPowerOf2Mask1(3) = 1

def checkPowerOf2Mask512(x: Int64) : Int64 =
  if (x & 512) != 0 then 1 else 0
checkPowerOf2Mask512(0) = 0
checkPowerOf2Mask512(511) = 0
checkPowerOf2Mask512(512) = 1
checkPowerOf2Mask512(1023) = 1
checkPowerOf2Mask512(1024) = 0

def checkPowerOf2Mask1024(x: Int64) : Int64 =
  if (x & 1024) != 0 then 1 else 0
checkPowerOf2Mask1024(0) = 0
checkPowerOf2Mask1024(1023) = 0
checkPowerOf2Mask1024(1024) = 1
checkPowerOf2Mask1024(2047) = 1
checkPowerOf2Mask1024(2048) = 0
