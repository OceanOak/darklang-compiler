// Register Allocation Tests
//
// Tests for register pressure and spilling scenarios.
// These test cases ensure register allocation works correctly when
// there are more live values than available registers.

// ===================================================================
// Register Pressure with Let Bindings
// ===================================================================

// 1-4 let bindings: should use registers only (X1-X10)
let x = 1 in x = 1
let x = 1 in let y = 2 in x + y = 3
let x = 1 in let y = 2 in let z = 3 in x + y + z = 6
let x = 1 in let y = 2 in let z = 3 in let w = 4 in x + y + z + w = 10

// 5+ let bindings: triggers spilling
let a = 1 in let b = 2 in let c = 3 in let d = 4 in let e = 5 in a + b + c + d + e = 15
let a = 1 in let b = 2 in let c = 3 in let d = 4 in let e = 5 in let f = 6 in a + b + c + d + e + f = 21
let a = 1 in let b = 2 in let c = 3 in let d = 4 in let e = 5 in let f = 6 in let g = 7 in a + b + c + d + e + f + g = 28

// 8+ let bindings: more spilling
let a = 1 in let b = 2 in let c = 3 in let d = 4 in let e = 5 in let f = 6 in let g = 7 in let h = 8 in a + b + c + d + e + f + g + h = 36

// 10 let bindings: at capacity
let a = 1 in let b = 2 in let c = 3 in let d = 4 in let e = 5 in let f = 6 in let g = 7 in let h = 8 in let i = 9 in let j = 10 in a + b + c + d + e + f + g + h + i + j = 55

// 12 let bindings: needs callee-saved or spilling
let a = 1 in let b = 2 in let c = 3 in let d = 4 in let e = 5 in let f = 6 in let g = 7 in let h = 8 in let i = 9 in let j = 10 in let k = 11 in let l = 12 in a + b + c + d + e + f + g + h + i + j + k + l = 78


// ===================================================================
// Register Pressure with Pattern Matching
// (These expose the bug where register values aren't preserved across blocks)
// ===================================================================

// 4 lets + pattern match (works - no spilling needed)
let x = 1 in let y = 2 in let z = 3 in let w = 4 in match [7, 8] with | [a, b] -> a + b | _ -> 99 = 15

// 5 lets + pattern match with operation (works)
let x = 1 in let y = 2 in let z = 3 in let w = 4 in let v = 5 in match [7, 8] with | [a, b] -> a + b | _ -> 99 = 15

// 5 lets + pattern match with direct return of first extracted element
let x = 1 in let y = 2 in let z = 3 in let w = 4 in let v = 5 in match [7, 8] with | [a, b] -> a | _ -> 99 = 7

// 5 lets + pattern match with direct return of second extracted element
let x = 1 in let y = 2 in let z = 3 in let w = 4 in let v = 5 in match [7, 8] with | [a, b] -> b | _ -> 99 = 8

// 5 lets + pattern match with constant return
let x = 1 in let y = 2 in let z = 3 in let w = 4 in let v = 5 in match [7, 8] with | [a, b] -> 42 | _ -> 99 = 42

// 5 lets + pattern match with a + 0 (works - forces operation)
let x = 1 in let y = 2 in let z = 3 in let w = 4 in let v = 5 in match [7, 8] with | [a, b] -> a + 0 | _ -> 99 = 7


// ===================================================================
// Cross-Block Value Preservation
// ===================================================================

// Values defined before branch must be available after
let x = 42 in if true then x else 0 = 42
let x = 42 in if false then 0 else x = 42

// Multiple values across branches
let x = 10 in let y = 20 in if true then x + y else 0 = 30
let x = 10 in let y = 20 in if false then 0 else x + y = 30

// Nested conditions with value preservation
let x = 5 in if x > 0 then if x > 3 then x else 0 else 0 = 5


// ===================================================================
// Pattern Matching with Value Preservation
// ===================================================================

// Match on integer with values from outer scope
let x = 100 in match 1 with | 1 -> x | _ -> 0 = 100

// Match on tuple with outer scope values
let x = 10 in match (1, 2) with | (a, b) -> x + a + b = 13

// ADT match with outer scope values
type MyOption = MyNone | MySome of Int64 let x = 100 in match MySome(42) with | MySome(n) -> x + n | MyNone -> 0 = 142


// ===================================================================
// Complex Register Pressure Scenarios
// ===================================================================

// Many live values across branches
let a = 1 in let b = 2 in let c = 3 in let d = 4 in let e = 5 in if a > 0 then a + b + c + d + e else 0 = 15

// Nested matches with many outer values
let x = 1 in let y = 2 in let z = 3 in match true with | true -> match false with | false -> x + y + z | true -> 0 | false -> 0 = 6

// Many values through multiple match levels
let a = 10 in let b = 20 in match 1 with | 1 -> let c = 30 in a + b + c | _ -> 0 = 60


// ===================================================================
// Spill and Reload Correctness
// ===================================================================

// Spilled value used multiple times
let a = 1 in let b = 2 in let c = 3 in let d = 4 in let e = 5 in let f = 6 in let g = 7 in let h = 8 in let i = 9 in let j = 10 in let k = 11 in k + k = 22

// Multiple spilled values used together
let a = 1 in let b = 2 in let c = 3 in let d = 4 in let e = 5 in let f = 6 in let g = 7 in let h = 8 in let i = 9 in let j = 10 in let k = 11 in let l = 12 in k + l = 23

// Early and late values used together
let a = 1 in let b = 2 in let c = 3 in let d = 4 in let e = 5 in let f = 6 in let g = 7 in let h = 8 in let i = 9 in let j = 10 in let k = 11 in let l = 12 in a + l = 13


// ===================================================================
// Float Values Across Calls
// ===================================================================

// Float argument must survive a call that can clobber float regs
def floatAcrossCall(r: Float) : Float = let list = [1, 2, 3] in let _ = Stdlib.List.length<Int64>(list) in r + 1.0
floatAcrossCall(2.0) = 3.0


// ===================================================================
// Live Interval Computation Tests
// ===================================================================

// Multiple variables live across several instructions - tests proper globalIdx incrementing
// If globalIdx were decremented instead of incremented, intervals would be inverted
// causing variables to appear non-overlapping when they actually overlap
let a = 100 in let b = a + 1 in let c = b + 1 in let d = c + 1 in let e = d + 1 in a + e = 204

// Terminator position globalIdx test - variables used in conditionals
// If terminator globalIdx were decremented instead of incremented, the variable used
// in the condition would have an incorrect live interval
let x = 10 in let y = 20 in let z = 30 in let w = 40 in let v = 50 in let u = 60 in let t = 70 in let cond = x > 5 in if cond then x + y + z + w + v + u + t else 0 = 280


// ===================================================================
// Stack Alignment Tests (Mutation #194)
// ===================================================================

// Tests for stack alignment calculation: ((size + 15) / 16) * 16
// The alignTo16 function rounds up to the nearest 16-byte boundary.
// If mutation changes + to -, alignment would be wrong causing memory corruption.

// Single spilled value - needs 16-byte aligned stack (not 0)
let a = 1 in let b = 2 in let c = 3 in let d = 4 in let e = 5 in let f = 6 in let g = 7 in let h = 8 in let i = 9 in let j = 10 in let k = 11 in let l = 12 in let m = 13 in a + b + c + d + e + f + g + h + i + j + k + l + m = 91

// Multiple spilled values with specific stack sizes that exercise alignment edge cases
// 14 values: tests stack allocation with multiple spills
let a1 = 1 in let b1 = 2 in let c1 = 3 in let d1 = 4 in let e1 = 5 in let f1 = 6 in let g1 = 7 in let h1 = 8 in let i1 = 9 in let j1 = 10 in let k1 = 11 in let l1 = 12 in let m1 = 13 in let n1 = 14 in a1 + b1 + c1 + d1 + e1 + f1 + g1 + h1 + i1 + j1 + k1 + l1 + m1 + n1 = 105

// 15 values: more pressure on alignment
let v1 = 1 in let v2 = 2 in let v3 = 3 in let v4 = 4 in let v5 = 5 in let v6 = 6 in let v7 = 7 in let v8 = 8 in let v9 = 9 in let v10 = 10 in let v11 = 11 in let v12 = 12 in let v13 = 13 in let v14 = 14 in let v15 = 15 in v1 + v2 + v3 + v4 + v5 + v6 + v7 + v8 + v9 + v10 + v11 + v12 + v13 + v14 + v15 = 120


// ===================================================================
// Interference Graph Building Tests (Mutation #201)
// ===================================================================

// Tests for interference edge generation at terminators.
// The buildInterferenceGraph function builds edges between all pairs
// of live variables at each program point. Mutation #201 affects the
// loop bounds for generating these pairwise edges.

// Multiple variables live at conditional branch terminator
// Variables a,b,c,d,e are all live at the if condition check
let a = 10 in let b = 20 in let c = 30 in let d = 40 in let e = 50 in if a > 0 then b + c + d + e else a = 140

// Many variables live at nested conditionals
let x1 = 1 in let x2 = 2 in let x3 = 3 in let x4 = 4 in let x5 = 5 in let x6 = 6 in if x1 > 0 then if x2 > 0 then x3 + x4 + x5 + x6 else 0 else 0 = 18

// Pattern match with multiple outer variables live at terminator
let p1 = 100 in let p2 = 200 in let p3 = 300 in let p4 = 400 in match 1 with | 1 -> p1 + p2 + p3 + p4 | _ -> 0 = 1000

// Variables used in both branches require interference edges
let m = 5 in let n = 10 in let o = 15 in let p = 20 in if true then m + n else o + p = 15


// ===================================================================
// Phi Coalescing Color Assignment Tests (Mutation #212)
// ===================================================================

// Tests for the color assignment loop bounds in colorVertexWithPartners.
// The loop iterates 0..numColors-1 to find available colors.
// If mutation changes -1 to +1, it would iterate 0..numColors+1,
// potentially assigning invalid out-of-range colors.

// High register pressure with phi nodes from conditional branches
// Creates phi nodes when variable 'result' is defined differently in each branch
let v1 = 1 in let v2 = 2 in let v3 = 3 in let v4 = 4 in let v5 = 5 in let v6 = 6 in let v7 = 7 in let v8 = 8 in let v9 = 9 in let v10 = 10 in let v11 = 11 in let v12 = 12 in let result = if v1 > 0 then v1 + v2 + v3 + v4 + v5 + v6 else v7 + v8 + v9 + v10 + v11 + v12 in result = 21

// Nested conditionals with phi coalescing under register pressure
let a1 = 1 in let a2 = 2 in let a3 = 3 in let a4 = 4 in let a5 = 5 in let a6 = 6 in let a7 = 7 in let a8 = 8 in let a9 = 9 in let a10 = 10 in let inner = if a1 > 0 then (if a2 > 0 then a3 + a4 else a5 + a6) else a7 + a8 in inner + a9 + a10 = 26

// Multiple phi nodes merged at control flow join with high pressure
let x1 = 10 in let x2 = 20 in let x3 = 30 in let x4 = 40 in let x5 = 50 in let x6 = 60 in let x7 = 70 in let x8 = 80 in let x9 = 90 in let x10 = 100 in let x11 = 110 in let x12 = 120 in let choice = if x1 < 50 then x2 + x3 else x4 + x5 in choice + x6 + x7 + x8 + x9 + x10 + x11 + x12 = 680


// ===================================================================
// Stack Slot Allocation Direction Tests (Mutation #213)
// ===================================================================

// Tests for correct stack slot allocation direction in coloringToAllocation.
// Stack slots should grow downward: -8, -16, -24, etc.
// Mutation #213 changes "nextStackSlot - 8" to "nextStackSlot + 8" for spills,
// which would cause stack slots to grow in wrong direction after first spill,
// leading to value corruption when multiple variables are spilled.

// Force multiple spills by having more live variables than allocatable registers (15)
// Each variable has a distinct value so corruption would be detectable
let s1 = 1 in let s2 = 2 in let s3 = 3 in let s4 = 4 in let s5 = 5 in let s6 = 6 in let s7 = 7 in let s8 = 8 in let s9 = 9 in let s10 = 10 in let s11 = 11 in let s12 = 12 in let s13 = 13 in let s14 = 14 in let s15 = 15 in let s16 = 16 in let s17 = 17 in s1 + s2 + s3 + s4 + s5 + s6 + s7 + s8 + s9 + s10 + s11 + s12 + s13 + s14 + s15 + s16 + s17 = 153

// 18 variables: ensures at least 3 spills that use separate stack slots
let t1 = 100 in let t2 = 200 in let t3 = 300 in let t4 = 400 in let t5 = 500 in let t6 = 600 in let t7 = 700 in let t8 = 800 in let t9 = 900 in let t10 = 1000 in let t11 = 1100 in let t12 = 1200 in let t13 = 1300 in let t14 = 1400 in let t15 = 1500 in let t16 = 1600 in let t17 = 1700 in let t18 = 1800 in t1 + t2 + t3 + t4 + t5 + t6 + t7 + t8 + t9 + t10 + t11 + t12 + t13 + t14 + t15 + t16 + t17 + t18 = 17100

// 20 variables: more spills to thoroughly test stack slot allocation
// Uses prime numbers to ensure any value corruption is detectable
let p1 = 2 in let p2 = 3 in let p3 = 5 in let p4 = 7 in let p5 = 11 in let p6 = 13 in let p7 = 17 in let p8 = 19 in let p9 = 23 in let p10 = 29 in let p11 = 31 in let p12 = 37 in let p13 = 41 in let p14 = 43 in let p15 = 47 in let p16 = 53 in let p17 = 59 in let p18 = 61 in let p19 = 67 in let p20 = 71 in p1 + p2 + p3 + p4 + p5 + p6 + p7 + p8 + p9 + p10 + p11 + p12 + p13 + p14 + p15 + p16 + p17 + p18 + p19 + p20 = 639


// ===================================================================
// Linear Scan Stack Slot Tests (Mutation #215)
// ===================================================================

// Mutation #215 targets the linearScan allocator's stack slot decrement.
// The linearScan function uses the same pattern as coloringToAllocation:
// nextStackSlot <- nextStackSlot - 8
// If mutated to +8, stack slots would overlap causing value corruption.
// Note: linearScan may be unused in current code paths, but these tests
// exercise the same pattern through coloringToAllocation for coverage.

// 22 variables: forces 7+ spills with distinct values
// Tests that each spilled variable gets a unique, non-overlapping stack slot
let q1 = 1000 in let q2 = 2000 in let q3 = 3000 in let q4 = 4000 in let q5 = 5000 in let q6 = 6000 in let q7 = 7000 in let q8 = 8000 in let q9 = 9000 in let q10 = 10000 in let q11 = 11000 in let q12 = 12000 in let q13 = 13000 in let q14 = 14000 in let q15 = 15000 in let q16 = 16000 in let q17 = 17000 in let q18 = 18000 in let q19 = 19000 in let q20 = 20000 in let q21 = 21000 in let q22 = 22000 in q1 + q2 + q3 + q4 + q5 + q6 + q7 + q8 + q9 + q10 + q11 + q12 + q13 + q14 + q15 + q16 + q17 + q18 + q19 + q20 + q21 + q22 = 253000

// Test with interleaved access patterns - spilled values accessed in different order than defined
let r1 = 11 in let r2 = 22 in let r3 = 33 in let r4 = 44 in let r5 = 55 in let r6 = 66 in let r7 = 77 in let r8 = 88 in let r9 = 99 in let r10 = 110 in let r11 = 121 in let r12 = 132 in let r13 = 143 in let r14 = 154 in let r15 = 165 in let r16 = 176 in let r17 = 187 in let r18 = 198 in let r19 = 209 in let r20 = 220 in r20 + r1 + r19 + r2 + r18 + r3 + r17 + r4 + r16 + r5 + r15 + r6 + r14 + r7 + r13 + r8 + r12 + r9 + r11 + r10 = 2310
