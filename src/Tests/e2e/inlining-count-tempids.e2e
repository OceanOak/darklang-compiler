// Inlining TempId Counting Tests
//
// These tests exercise the countTempIds function in the ANF inlining pass,
// specifically the case where If expressions have Let bindings in both branches.
// The count should be: countTempIds(thenBranch) + countTempIds(elseBranch)
//
// The inlining pass uses function body size (counted in TempIds) to decide
// whether to inline. The default MaxFunctionSize is 20.

// ===================================================================
// Basic If with Let bindings in both branches
// ===================================================================
// Tests that Let bindings in both branches are counted correctly

// Simple case: one Let in each branch
def ifWithLets(flag: Bool) : Int64 =
  if flag then
    let x = 10 in x
  else
    let y = 20 in y
ifWithLets(true) = 10
ifWithLets(false) = 20

// Multiple Lets in each branch (should sum both counts)
def ifWithMultipleLets(flag: Bool) : Int64 =
  if flag then
    let a = 1 in
    let b = 2 in
    let c = 3 in
    a + b + c
  else
    let x = 10 in
    let y = 20 in
    x + y
ifWithMultipleLets(true) = 6
ifWithMultipleLets(false) = 30

// ===================================================================
// Nested If expressions
// ===================================================================
// Tests counting in nested If structures

def nestedIf(outer: Bool, inner: Bool) : Int64 =
  if outer then
    if inner then
      let a = 1 in
      let b = 2 in
      a + b
    else
      let c = 3 in c
  else
    let d = 4 in
    let e = 5 in
    d + e
nestedIf(true, true) = 3
nestedIf(true, false) = 3
nestedIf(false, true) = 9
nestedIf(false, false) = 9

// ===================================================================
// Functions with large If bodies (near inlining threshold)
// ===================================================================
// The default MaxFunctionSize is 20 TempIds.
// These functions are designed to have many Let bindings in If branches.

// Function with 10 Lets in then-branch and 10 in else-branch
// Total should be 20, right at the threshold
def largeIfFunction(flag: Bool) : Int64 =
  if flag then
    let a1 = 1 in
    let a2 = 2 in
    let a3 = 3 in
    let a4 = 4 in
    let a5 = 5 in
    let a6 = 6 in
    let a7 = 7 in
    let a8 = 8 in
    let a9 = 9 in
    let a10 = 10 in
    a1 + a2 + a3 + a4 + a5 + a6 + a7 + a8 + a9 + a10
  else
    let b1 = 10 in
    let b2 = 20 in
    let b3 = 30 in
    let b4 = 40 in
    let b5 = 50 in
    let b6 = 60 in
    let b7 = 70 in
    let b8 = 80 in
    let b9 = 90 in
    let b10 = 100 in
    b1 + b2 + b3 + b4 + b5 + b6 + b7 + b8 + b9 + b10

largeIfFunction(true) = 55
largeIfFunction(false) = 550

// Function with asymmetric branches (to test + vs - in counting)
// then-branch: 15 Lets, else-branch: 5 Lets
// With +: 20 (at threshold)
// With -: 10 (well below threshold, would be inlined)
def asymmetricIfFunction(flag: Bool) : Int64 =
  if flag then
    let a1 = 1 in
    let a2 = 2 in
    let a3 = 3 in
    let a4 = 4 in
    let a5 = 5 in
    let a6 = 6 in
    let a7 = 7 in
    let a8 = 8 in
    let a9 = 9 in
    let a10 = 10 in
    let a11 = 11 in
    let a12 = 12 in
    let a13 = 13 in
    let a14 = 14 in
    let a15 = 15 in
    a1 + a2 + a3 + a4 + a5 + a6 + a7 + a8 + a9 + a10 + a11 + a12 + a13 + a14 + a15
  else
    let b1 = 100 in
    let b2 = 200 in
    let b3 = 300 in
    let b4 = 400 in
    let b5 = 500 in
    b1 + b2 + b3 + b4 + b5

asymmetricIfFunction(true) = 120
asymmetricIfFunction(false) = 1500

// ===================================================================
// Function calling another function with If and Lets
// ===================================================================
// Tests that inlining decisions cascade correctly

def helperWithIf(x: Int64) : Int64 =
  if x > 0 then
    let pos = x * 2 in pos
  else
    let neg = x * -1 in neg

def callerOfHelper(n: Int64) : Int64 =
  let a = helperWithIf(n) in
  let b = helperWithIf(-n) in
  a + b

callerOfHelper(5) = 15
callerOfHelper(-3) = 9

// ===================================================================
// Complex nested structure
// ===================================================================
// Multiple levels of nesting with Let bindings at each level

def complexNested(a: Bool, b: Bool, c: Bool) : Int64 =
  if a then
    let x1 = 100 in
    if b then
      let x2 = x1 + 10 in
      if c then
        let x3 = x2 + 1 in x3
      else
        let x4 = x2 + 2 in x4
    else
      let x5 = x1 + 20 in x5
  else
    let y1 = 200 in
    if b then
      let y2 = y1 + 30 in y2
    else
      let y3 = y1 + 40 in y3

complexNested(true, true, true) = 111
complexNested(true, true, false) = 112
complexNested(true, false, true) = 120
complexNested(true, false, false) = 120
complexNested(false, true, true) = 230
complexNested(false, true, false) = 230
complexNested(false, false, true) = 240
complexNested(false, false, false) = 240

// ===================================================================
// Inlining Change Flag in If Expression (Mutation #43)
// ===================================================================
// Tests for the change flag propagation in inlineInExpr's If case (line 403).
// The mutation changes || to && when combining changed1 and changed2.
//
// With ||: changed = changed1 || changed2 (either branch having inlining is enough)
// With &&: changed = changed1 && changed2 (WRONG - both branches must have inlining)
//
// Note: This is an "equivalent mutant" - the changed flag is currently unused
// in the inlining pass (it's computed but discarded). These tests document
// the behavior and ensure inlining works correctly when only one branch of
// an If expression contains a function call that gets inlined.

// Small helper function that will be inlined (size 1, well under MaxFunctionSize=20)
def addTwo(x: Int64) : Int64 = x + 2

// If expression where only the then-branch has a call that gets inlined
// The else-branch is a simple expression with no function calls
def ifWithInlineInThenOnly(flag: Bool, n: Int64) : Int64 =
  if flag then
    let result = addTwo(n) in  // This call will be inlined (changed1 = true)
    result
  else
    n * 3                      // No call to inline (changed2 = false)

ifWithInlineInThenOnly(true, 10) = 12
ifWithInlineInThenOnly(false, 10) = 30

// If expression where only the else-branch has a call that gets inlined
// The then-branch is a simple expression with no function calls
def ifWithInlineInElseOnly(flag: Bool, n: Int64) : Int64 =
  if flag then
    n * 4                      // No call to inline (changed1 = false)
  else
    let result = addTwo(n) in  // This call will be inlined (changed2 = true)
    result

ifWithInlineInElseOnly(true, 5) = 20
ifWithInlineInElseOnly(false, 5) = 7

// Nested If where inner If has inlining only in one branch
// This tests change flag propagation through nested structures
def nestedIfWithPartialInline(outer: Bool, inner: Bool, n: Int64) : Int64 =
  if outer then
    if inner then
      addTwo(n)    // Inlined (changed = true for inner If)
    else
      n + 100      // Not a call (changed = false for inner If's else)
  else
    n * 5          // No calls in outer else branch

nestedIfWithPartialInline(true, true, 10) = 12
nestedIfWithPartialInline(true, false, 10) = 110
nestedIfWithPartialInline(false, true, 10) = 50
nestedIfWithPartialInline(false, false, 10) = 50

// ===================================================================
// Program-Level Inlining Change Flag (Mutation #44)
// ===================================================================
// Tests for the anyChanged flag accumulation in inlineProgram's fold (line 452).
// The mutation changes || to && when combining anyChanged and changed.
//
// With ||: anyChanged becomes true if ANY function had inlining
// With &&: anyChanged would only be true if ALL functions had inlining
//
// Note: This is an "equivalent mutant" - the anyChanged flag is computed
// but discarded with _ on line 448. These tests document the behavior and
// ensure that inlining works correctly across multiple functions, where
// some functions have inlining opportunities and others don't.

// Small helper that will be inlined (size 1)
def tiny(x: Int64) : Int64 = x + 1

// Function that calls tiny - the call will be inlined
def callerWithInline(n: Int64) : Int64 =
  let a = tiny(n) in
  let b = tiny(a) in
  b

// Function with no inlining opportunities (no calls to inline-able functions)
def noInline(n: Int64) : Int64 =
  let x = n * 2 in
  let y = x + 3 in
  y

// Test that both functions work correctly when processed together.
// The fold processes functions in order. With the mutation:
// - callerWithInline: changed=true (has inlining)
// - noInline: changed=false (no calls to inline)
// With ||: anyChanged = true || false = true (then true && false = false for 2nd)
// Actually: fold goes: ([], varGen, false) -> callerWithInline -> (funcs, varGen', true)
//                                           -> noInline -> (funcs', varGen'', true || false = true)
// With &&: anyChanged = true && false = false
// The actual inlining still happens regardless of the flag value.
callerWithInline(5) = 7
noInline(10) = 23

// Multiple functions with varying inlining behavior
def helper1(x: Int64) : Int64 = x * 3
def helper2(x: Int64) : Int64 = x - 1

// This function has inlining (calls helper1 and helper2)
def mixedCaller(n: Int64) : Int64 =
  let a = helper1(n) in
  let b = helper2(a) in
  b

// This function has no inlining opportunities
def pureComputation(n: Int64) : Int64 =
  let squared = n * n in
  let cubed = squared * n in
  cubed - squared

// Verify behavior when multiple functions process through the fold
mixedCaller(4) = 11
pureComputation(3) = 18
