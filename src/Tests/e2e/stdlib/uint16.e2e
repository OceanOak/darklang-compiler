// Stdlib.UInt16 Tests
// Minimal coverage for integer operations

UInt16.add(10us, 9us) = 19
UInt16.sub(10us, 9us) = 1
UInt16.mul(8us, 8us) = 64
UInt16.div(10us, 5us) = 2
UInt16.max(5us, 6us) = 6
UInt16.min(5us, 6us) = 5
UInt16.mod(15us, 6us) = 3
UInt16.absoluteValue(5us) = 5
UInt16.negate(0us) = 0
UInt16.power(2us, 5us) = 32
UInt16.clamp(10us, 5us, 15us) = 10
UInt16.greaterThan(20us, 1us) = true
UInt16.greaterThanOrEqualTo(5us, 5us) = true
UInt16.lessThan(6us, 8us) = true
UInt16.lessThanOrEqualTo(5us, 5us) = true
UInt16.toString(42us) = 42
UInt16.isEven(2us) = true
UInt16.isOdd(3us) = true
UInt16.sum([1us, 2us, 3us]) = 6
UInt16.bitwiseAnd(6us, 3us) = 2
UInt16.bitwiseOr(4us, 1us) = 5
UInt16.bitwiseXor(5us, 3us) = 6
UInt16.shiftLeft(1us, 2us) = 4
UInt16.shiftRight(8us, 2us) = 2
UInt16.bitwiseNot(0us) = -1
UInt16.popcount(7us) = 3
