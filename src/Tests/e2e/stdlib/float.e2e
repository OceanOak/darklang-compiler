// Stdlib.Float tests

// sqrt - now with full precision
Float.sqrt(4.0) = 2.0
Float.sqrt(9.0) = 3.0
Float.sqrt(2.0) = 1.41421356237
Float.sqrt(0.0) = 0.0
Float.sqrt(1.0) = 1.0
Float.sqrt(100.0) = 10.0

// abs - now with full precision
Float.abs(5.5) = 5.5
Float.abs(-5.5) = 5.5
Float.abs(0.0) = 0.0
Float.abs(-0.0) = 0.0
Float.abs(-123.456) = 123.456

// negate
Float.negate(3.14) = -3.14
Float.negate(-3.14) = 3.14
// Float.negate(0.0) correctly displays as -0.0 (IEEE 754 signed zero)
Float.negate(0.0) = -0.0

// toInt (truncates toward zero)
Float.toInt(3.7) = 3
Float.toInt(3.2) = 3
Float.toInt(-3.7) = -3
Float.toInt(-3.2) = -3
Float.toInt(0.0) = 0
Float.toInt(100.99) = 100

// Int64.toFloat
Int64.toFloat(42) = 42.0
Int64.toFloat(0) = 0.0
Int64.toFloat(-100) = -100.0

// Combined operations
Float.sqrt(Float.abs(-16.0)) = 4.0
Float.abs(Float.negate(5.0)) = 5.0
Float.toInt(Float.sqrt(100.0)) = 10
Int64.toFloat(Float.toInt(9.99)) = 9.0

// Float comparisons (already work, but good to test with new functions)
Float.sqrt(4.0) > 1.0 = true
Float.sqrt(4.0) == 2.0 = true
Float.abs(-5.0) > 4.0 = true

// Float64.toBits - IEEE 754 bit representation
// Note: UInt64 values with high bit set are printed as signed (compiler limitation)
Float64.toBits(1.0) = 4607182418800017408
Float64.toBits(-1.0) = -4616189618054758400
Float64.toBits(0.0) = 0

// Float64.toString - special cases
// -0.0 correctly displays as "-0.0" (IEEE 754 signed zero)
Float64.toString(0.0) = "0.0"
Float64.toString(-0.0) = "-0.0"
