// Stdlib.UInt32 Tests
// Ported from https://github.com/darklang/dark/tree/main/backend/testfiles/execution/stdlib
//
// Tests for UInt32 module functions

// ===================================================================
// UInt32.add - Add two integers
// ===================================================================

UInt32.add(10ul, 9ul) = 19ul
UInt32.add(0ul, 0ul) = 0ul
UInt32.add(5ul, 5ul) = 10ul
UInt32.add(100ul, 200ul) = 300ul

// ===================================================================
// UInt32.sub - Subtract two integers
// ===================================================================

UInt32.sub(10ul, 9ul) = 1ul
UInt32.sub(10ul, 0ul) = 10ul
UInt32.sub(100ul, 50ul) = 50ul
UInt32.sub(5ul, 0ul) = 5ul

// ===================================================================
// UInt32.mul - Multiply two integers
// ===================================================================

UInt32.mul(8ul, 8ul) = 64ul
UInt32.mul(0ul, 100ul) = 0ul
UInt32.mul(5ul, 5ul) = 25ul
UInt32.mul(100ul, 100ul) = 10000ul

// ===================================================================
// UInt32.div - Divide two integers
// ===================================================================

UInt32.div(10ul, 5ul) = 2ul
UInt32.div(10ul, 3ul) = 3ul
UInt32.div(100ul, 10ul) = 10ul
UInt32.div(10ul, 2ul) = 5ul

// ===================================================================
// UInt32.mod - Modulo operation
// ===================================================================

UInt32.mod(15ul, 6ul) = 3ul
UInt32.mod(10ul, 3ul) = 1ul
UInt32.mod(100ul, 7ul) = 2ul
UInt32.mod(20ul, 3ul) = 2ul

// ===================================================================
// UInt32.max - Maximum of two integers
// ===================================================================

UInt32.max(5ul, 6ul) = 6ul
UInt32.max(6ul, 5ul) = 6ul
UInt32.max(10ul, 20ul) = 20ul
UInt32.max(0ul, 0ul) = 0ul

// ===================================================================
// UInt32.min - Minimum of two integers
// ===================================================================

UInt32.min(5ul, 6ul) = 5ul
UInt32.min(6ul, 5ul) = 5ul
UInt32.min(10ul, 20ul) = 10ul
UInt32.min(0ul, 0ul) = 0ul

// ===================================================================
// UInt32.absoluteValue - Absolute value
// ===================================================================

UInt32.absoluteValue(5ul) = 5ul
UInt32.absoluteValue(0ul) = 0ul
UInt32.absoluteValue(100ul) = 100ul
UInt32.absoluteValue(1ul) = 1ul

// ===================================================================
// UInt32.negate - Negate an integer
// ===================================================================

UInt32.negate(0ul) = 0ul
UInt32.negate(1ul) = 4294967295ul
UInt32.negate(5ul) = 4294967291ul
UInt32.negate(100ul) = 4294967196ul

// ===================================================================
// UInt32.power - Raise to a power
// ===================================================================

UInt32.power(8ul, 5ul) = 32768ul
UInt32.power(2ul, 10ul) = 1024ul
UInt32.power(0ul, 0ul) = 1ul
UInt32.power(5ul, 0ul) = 1ul
UInt32.power(5ul, 1ul) = 5ul
UInt32.power(2ul, 8ul) = 256ul

// ===================================================================
// UInt32.clamp - Clamp value between limits
// ===================================================================

UInt32.clamp(5ul, 0ul, 5ul) = 5ul
UInt32.clamp(3ul, 0ul, 2ul) = 2ul
UInt32.clamp(1ul, 0ul, 5ul) = 1ul
UInt32.clamp(10ul, 5ul, 15ul) = 10ul
UInt32.clamp(2ul, 5ul, 10ul) = 5ul

// ===================================================================
// UInt32.greaterThan - Greater than comparison
// ===================================================================

UInt32.greaterThan(20ul, 1ul) = true
UInt32.greaterThan(1ul, 20ul) = false
UInt32.greaterThan(5ul, 5ul) = false

// ===================================================================
// UInt32.greaterThanOrEqualTo - Greater than or equal comparison
// ===================================================================

UInt32.greaterThanOrEqualTo(6ul, 1ul) = true
UInt32.greaterThanOrEqualTo(1ul, 6ul) = false
UInt32.greaterThanOrEqualTo(5ul, 5ul) = true

// ===================================================================
// UInt32.lessThan - Less than comparison
// ===================================================================

UInt32.lessThan(6ul, 8ul) = true
UInt32.lessThan(8ul, 6ul) = false
UInt32.lessThan(5ul, 5ul) = false

// ===================================================================
// UInt32.lessThanOrEqualTo - Less than or equal comparison
// ===================================================================

UInt32.lessThanOrEqualTo(6ul, 8ul) = true
UInt32.lessThanOrEqualTo(8ul, 6ul) = false
UInt32.lessThanOrEqualTo(5ul, 5ul) = true

// ===================================================================
// UInt32.toString - Convert integer to string
// ===================================================================

UInt32.toString(0ul) = "0"
UInt32.toString(42ul) = "42"
UInt32.toString(5ul) = "5"
UInt32.toString(1234567890ul) = "1234567890"

// ===================================================================
// UInt32.isEven - Check if integer is even
// ===================================================================

UInt32.isEven(0ul) = true
UInt32.isEven(2ul) = true
UInt32.isEven(4ul) = true
UInt32.isEven(6ul) = true
UInt32.isEven(1ul) = false
UInt32.isEven(3ul) = false
UInt32.isEven(5ul) = false

// ===================================================================
// UInt32.isOdd - Check if integer is odd
// ===================================================================

UInt32.isOdd(1ul) = true
UInt32.isOdd(3ul) = true
UInt32.isOdd(5ul) = true
UInt32.isOdd(0ul) = false
UInt32.isOdd(2ul) = false
UInt32.isOdd(4ul) = false
UInt32.isOdd(6ul) = false

// ===================================================================
// UInt32.sum - Sum all integers in a list
// ===================================================================

UInt32.sum([1ul, 2ul, 3ul, 4ul, 5ul]) = 15ul
UInt32.sum([]) = 0ul
UInt32.sum([100ul]) = 100ul
UInt32.sum([1ul, 1ul, 2ul, 2ul]) = 6ul
UInt32.sum([10ul, 20ul, 30ul]) = 60ul

