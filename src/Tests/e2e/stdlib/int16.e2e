// Stdlib.Int16 Tests
// Ported from https://github.com/darklang/dark/tree/main/backend/testfiles/execution/stdlib
//
// Tests for Int16 module functions

// ===================================================================
// Int16.add - Add two integers
// ===================================================================

Int16.add(10s, 9s) = 19
Int16.add(0s, 0s) = 0
Int16.add(-5s, 5s) = 0
Int16.add(100s, 200s) = 300

// ===================================================================
// Int16.sub - Subtract two integers
// ===================================================================

Int16.sub(10s, 9s) = 1
Int16.sub(0s, 0s) = 0
Int16.sub(100s, 50s) = 50
Int16.sub(5s, 10s) = -5

// ===================================================================
// Int16.mul - Multiply two integers
// ===================================================================

Int16.mul(8s, 8s) = 64
Int16.mul(0s, 100s) = 0
Int16.mul(-5s, 5s) = -25
Int16.mul(100s, 100s) = 10000

// ===================================================================
// Int16.div - Divide two integers
// ===================================================================

Int16.div(10s, 5s) = 2
Int16.div(10s, 3s) = 3
Int16.div(100s, 10s) = 10
Int16.div(-10s, 2s) = -5

// ===================================================================
// Int16.mod - Modulo operation
// ===================================================================

Int16.mod(15s, 6s) = 3
Int16.mod(10s, 3s) = 1
Int16.mod(100s, 7s) = 2
Int16.mod(-10s, 3s) = 2

// ===================================================================
// Int16.max - Maximum of two integers
// ===================================================================

Int16.max(5s, 6s) = 6
Int16.max(6s, 5s) = 6
Int16.max(-5s, -10s) = -5
Int16.max(0s, 0s) = 0

// ===================================================================
// Int16.min - Minimum of two integers
// ===================================================================

Int16.min(5s, 6s) = 5
Int16.min(6s, 5s) = 5
Int16.min(-5s, -10s) = -10
Int16.min(0s, 0s) = 0

// ===================================================================
// Int16.absoluteValue - Absolute value
// ===================================================================

Int16.absoluteValue(-5s) = 5
Int16.absoluteValue(5s) = 5
Int16.absoluteValue(0s) = 0
Int16.absoluteValue(-100s) = 100

// ===================================================================
// Int16.negate - Negate an integer
// ===================================================================

Int16.negate(-5s) = 5
Int16.negate(5s) = -5
Int16.negate(0s) = 0
Int16.negate(100s) = -100

// ===================================================================
// Int16.power - Raise to a power
// ===================================================================

Int16.power(8s, 4s) = 4096
Int16.power(2s, 10s) = 1024
Int16.power(0s, 0s) = 1
Int16.power(5s, 0s) = 1
Int16.power(5s, 1s) = 5
Int16.power(2s, 8s) = 256

// ===================================================================
// Int16.clamp - Clamp value between limits
// ===================================================================

Int16.clamp(-5s, -2s, 5s) = -2
Int16.clamp(3s, 0s, 2s) = 2
Int16.clamp(1s, 0s, 5s) = 1
Int16.clamp(10s, 5s, 15s) = 10
Int16.clamp(0s, 5s, 10s) = 5

// ===================================================================
// Int16.greaterThan - Greater than comparison
// ===================================================================

Int16.greaterThan(20s, 1s) = true
Int16.greaterThan(1s, 20s) = false
Int16.greaterThan(5s, 5s) = false

// ===================================================================
// Int16.greaterThanOrEqualTo - Greater than or equal comparison
// ===================================================================

Int16.greaterThanOrEqualTo(6s, 1s) = true
Int16.greaterThanOrEqualTo(1s, 6s) = false
Int16.greaterThanOrEqualTo(5s, 5s) = true

// ===================================================================
// Int16.lessThan - Less than comparison
// ===================================================================

Int16.lessThan(6s, 8s) = true
Int16.lessThan(8s, 6s) = false
Int16.lessThan(5s, 5s) = false

// ===================================================================
// Int16.lessThanOrEqualTo - Less than or equal comparison
// ===================================================================

Int16.lessThanOrEqualTo(6s, 8s) = true
Int16.lessThanOrEqualTo(8s, 6s) = false
Int16.lessThanOrEqualTo(5s, 5s) = true

// ===================================================================
// Int16.toString - Convert integer to string
// ===================================================================

Int16.toString(0s) = 0
Int16.toString(42s) = 42
Int16.toString(-5s) = -5
Int16.toString(12345s) = 12345

// ===================================================================
// Int16.isEven - Check if integer is even
// ===================================================================

Int16.isEven(0s) = true
Int16.isEven(2s) = true
Int16.isEven(4s) = true
Int16.isEven(-2s) = true
Int16.isEven(1s) = false
Int16.isEven(3s) = false
Int16.isEven(-1s) = false

// ===================================================================
// Int16.isOdd - Check if integer is odd
// ===================================================================

Int16.isOdd(1s) = true
Int16.isOdd(3s) = true
Int16.isOdd(-1s) = true
Int16.isOdd(0s) = false
Int16.isOdd(2s) = false
Int16.isOdd(4s) = false
Int16.isOdd(-2s) = false

// ===================================================================
// Int16.sum - Sum all integers in a list
// ===================================================================

Int16.sum([1s, 2s, 3s, 4s, 5s]) = 15
Int16.sum([]) = 0
Int16.sum([100s]) = 100
Int16.sum([1s, -1s, 2s, -2s]) = 0
Int16.sum([10s, 20s, 30s]) = 60

// ===================================================================
// NOTE: Functions not yet implemented due to missing types or features
// ===================================================================

