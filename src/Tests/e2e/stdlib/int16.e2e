// Stdlib.Int16 Tests
// Minimal coverage for integer operations

Int16.add(10s, 9s) = 19
Int16.sub(10s, 9s) = 1
Int16.mul(8s, 8s) = 64
Int16.div(10s, 5s) = 2
Int16.max(5s, 6s) = 6
Int16.min(5s, 6s) = 5
Int16.mod(15s, 6s) = 3
Int16.absoluteValue(-5s) = 5
Int16.negate(5s) = -5
Int16.power(2s, 5s) = 32
Int16.clamp(10s, 5s, 15s) = 10
Int16.greaterThan(20s, 1s) = true
Int16.greaterThanOrEqualTo(5s, 5s) = true
Int16.lessThan(6s, 8s) = true
Int16.lessThanOrEqualTo(5s, 5s) = true
Int16.toString(-5s) = -5
Int16.isEven(2s) = true
Int16.isOdd(3s) = true
Int16.sum([1s, 2s, 3s]) = 6
Int16.bitwiseAnd(6s, 3s) = 2
Int16.bitwiseOr(4s, 1s) = 5
Int16.bitwiseXor(5s, 3s) = 6
Int16.shiftLeft(1s, 2s) = 4
Int16.shiftRight(8s, 2s) = 2
Int16.bitwiseNot(0s) = -1
Int16.popcount(7s) = 3
