// Tuple tests for Phase 7 Milestone 1

// Basic tuple creation and access
// Note: Currently tuples cannot be directly printed, so we access elements

// 2-element tuple - first element
let t = (1, 2) in t.0 = 1

// 2-element tuple - second element
let t = (1, 2) in t.1 = 2

// 3-element tuple - all elements
let t = (10, 20, 30) in t.0 = 10
let t = (10, 20, 30) in t.1 = 20
let t = (10, 20, 30) in t.2 = 30

// Tuple with negative numbers
let t = (-1, -2) in t.0 = -1
let t = (-1, -2) in t.1 = -2

// Tuple with zero
let t = (0, 1) in t.0 = 0
let t = (0, 1) in t.1 = 1

// Nested tuple access (single level)
let t = (100, 200) in t.0 + t.1 = 300

// Tuple with boolean values
let t = (true, false) in t.0 = true
let t = (true, false) in t.1 = false

// Tuple elements in arithmetic
let t = (5, 3) in t.0 - t.1 = 2
let t = (5, 3) in t.0 * t.1 = 15

// Multiple tuples
let a = (1, 2) in let b = (3, 4) in a.0 + b.1 = 5

// Large tuple (4 elements)
let t = (1, 2, 3, 4) in t.0 + t.1 + t.2 + t.3 = 10


// ===================================================================
// Let-Pattern Matching with Tuples
// ===================================================================

// Basic tuple destructuring - 2 elements
let (a, b) = (1, 2) in a = 1
let (a, b) = (1, 2) in b = 2
let (a, b) = (10, 20) in a + b = 30

// 3-element tuple destructuring
let (a, b, c) = (1, 2, 3) in a = 1
let (a, b, c) = (1, 2, 3) in b = 2
let (a, b, c) = (1, 2, 3) in c = 3
let (a, b, c) = (10, 20, 30) in a + b + c = 60

// 4-element tuple destructuring
let (a, b, c, d) = (1, 2, 3, 4) in a + b + c + d = 10

// Tuple destructuring with expressions
let (x, y) = (3 + 4, 5 * 2) in x = 7
let (x, y) = (3 + 4, 5 * 2) in y = 10
let (x, y) = (3 + 4, 5 * 2) in x + y = 17

// Nested let with tuple destructuring
let (a, b) = (1, 2) in let (c, d) = (3, 4) in a + b + c + d = 10

// Tuple from variable
let t = (5, 10) in let (a, b) = t in a * b = 50

// Wildcard in tuple pattern
let (a, _) = (42, 99) in a = 42
let (_, b) = (99, 42) in b = 42
let (a, _, c) = (1, 2, 3) in a + c = 4

// Tuple destructuring with negative numbers
let (a, b) = (-5, 10) in a + b = 5

// Complex expression using destructured values
let (x, y) = (6, 4) in x * y - x + y = 22

// ===================================================================
// Tuple Printing
// ===================================================================

// Basic tuple printing
(1, 2) = (1, 2)
(42, 99) = (42, 99)
(0, 0) = (0, 0)

// 3-element tuple printing
(1, 2, 3) = (1, 2, 3)
(10, 20, 30) = (10, 20, 30)

// Tuple with negative numbers
(-1, -2) = (-1, -2)
(5, -10) = (5, -10)

// Tuple with computed values
let x = 5 in (x, x + 1) = (5, 6)
(3 + 4, 5 * 2) = (7, 10)

// ===================================================================
// String Extraction from Tuples
// ===================================================================

// Extract string from first position
match ("hello", 5) with | (a, _) -> a = hello

// Extract string from second position
match (5, "world") with | (_, b) -> b = world

// Extract string using let-pattern
let (s, _) = ("test", 42) in s = test
let (_, s) = (42, "test") in s = test

// Extract string alongside other values
let (a, s, b) = (1, "middle", 2) in s = middle

// ===================================================================
// Tuples with Floats (GpToFp/FpToGp conversion tests)
// ===================================================================

// Float in first position
(3.14, 42).0 = 3.14
(3.14, 42).1 = 42

// Float in second position
(42, 3.14).0 = 42
(42, 3.14).1 = 3.14

// All floats
(1.0, 2.0).0 + (1.0, 2.0).1 = 3.0

// Mixed float/int/bool
(1.5, true, 42).0 = 1.5
(1.5, true, 42).1 = true
(1.5, true, 42).2 = 42

// Float in last position of 3-tuple
(10, 20, 3.14).2 = 3.14

// Float tuple destructuring
let (a, b) = (1.5, 2.5) in a + b = 4.0

// Mixed destructuring with float
let (x, y, z) = (1.0, 42, 2.0) in x + z = 3.0

// Float tuple in let binding
let t = (3.14, 2.71) in t.0 = 3.14
let t = (3.14, 2.71) in t.1 = 2.70999999999

// Float tuple with arithmetic on access
let t = (1.5, 2.5) in t.0 * t.1 = 3.75

// Nested tuple with float
let t = ((1.0, 2.0), 3) in t.1 = 3

// Float tuple printing
(1.0, 2.0) = (1.0, 2.0)
(3.14, 42) = (3.14, 42)
(42, 3.14) = (42, 3.14)

// ===================================================================
// Tuple pattern index ordering (kills mutation #65)
// Tests that tuple destructuring uses correct indices for each element
// If the index increment were wrong, elements would be misbound
// ===================================================================

// Verify second element gets index 1, not index -1 or 0
// Using subtraction to detect if wrong element is bound
let (a, b) = (100, 37) in b - a = -63

// Three-element tuple: verify third element uses index 2
let (x, y, z) = (10, 20, 30) in z - x = 20

// Four-element tuple: verify all indices are correct
let (a, b, c, d) = (1000, 100, 10, 1) in d - a = -999

// ===================================================================
// Tuple pattern index ordering with guards (kills mutation #66)
// Tests that tuple destructuring in match+guard expressions uses
// correct indices for each element. The guard path has a separate
// collectFromTuple function that increments idx for each element.
// ===================================================================

// Verify second element gets correct index in guard context
// Using subtraction to detect if wrong element is bound
match (100, 37) with | (a, b) when b < a -> b - a | _ -> 999 = -63

// Three-element tuple with guard: verify third element uses index 2
match (10, 20, 30) with | (x, y, z) when z > y -> z - x | _ -> 999 = 20

// Four-element tuple with guard: verify all indices are correct
match (1000, 100, 10, 1) with | (a, b, c, d) when d < c -> d - a | _ -> 999 = -999

// ===================================================================
// Tuple pattern matching with float elements (kills mutation #114)
// Tests that tuple destructuring in match expressions correctly
// preserves float types for later tuple positions. If the type lookup
// uses > instead of < for index bounds checking, all elements would
// be typed as Int64, causing float operations to fail.
// ===================================================================

// Match tuple with float in second position - verify float arithmetic works
match (42, 2.5) with | (_, f) -> f * 2.0 = 5.0

// Match tuple with float in third position - verify index 2 gets correct type
match (1, 2, 3.5) with | (_, _, f) -> f + 1.5 = 5.0

// Match tuple with mixed types - extract float from middle position
match (10, 1.5, 20) with | (_, f, _) -> f * 4.0 = 6.0

// Match tuple with all floats - verify all positions get float type
match (1.0, 2.0, 3.0) with | (a, b, c) -> a + b + c = 6.0
