// =====================================================
// Lists of Tuples
// =====================================================

// List of 2-tuples
match [(1, 2), (3, 4)] with | [t1, t2] -> t1.0 + t2.1 | _ -> 0 = 5

// List of 2-tuples - product
match [(2, 3), (4, 5)] with | [t1, t2] -> t1.0 * t1.1 + t2.0 * t2.1 | _ -> 0 = 26

// Single tuple in list
match [(10, 20)] with | [t] -> t.0 + t.1 | _ -> 0 = 30

// Recursive list construction with tuple elements
def makePairs(n: Int64) : List<(Int64, Int64)> =
    if n <= 0 then
        []
    else
        [(n, n + 1), ...makePairs(n - 1)]

let pairs = makePairs(1) in match pairs with | [(a, b)] -> a + b | _ -> 999 = 3

// Tuple pattern destructuring in list with non-commutative operation
// This test ensures tuple element indices are extracted correctly (kills mutation #61)
match [(10, 3)] with | [(a, b)] -> a - b | _ -> 0 = 7

// Three-element tuple in list with subtraction to verify correct index ordering
match [(100, 40, 7)] with | [(a, b, c)] -> a - b - c | _ -> 0 = 53

// List of float tuples
match [(1.0, 2.5), (3.5, 4.0)] with | [t1, t2] -> t1.0 + t1.1 + t2.0 + t2.1 | _ -> 0.0 = 11.0

// Float tuple comparison inside list
match [("a", 0.5)] with | [t] -> if t.1 < 0.6 then 1 else 0 | _ -> 0 = 1

// Cumulative float tuple selection in list
def makeCumulative(table: List<(Int64, Float)>, running: Float) : List<(Int64, Float)> = match Stdlib.List.head<(Int64, Float)>(table) with | None -> [] | Some(item) -> let c = Stdlib.Tuple2.first<Int64, Float>(item) in let p = Stdlib.Tuple2.second<Int64, Float>(item) in let newRunning = running + p in match Stdlib.List.tail<(Int64, Float)>(table) with | None -> [(c, newRunning)] | Some(rest) -> Stdlib.List.push<(Int64, Float)>(makeCumulative(rest, newRunning), (c, newRunning)) def selectRandom(table: List<(Int64, Float)>, r: Float, idx: Int64) : Int64 = match Stdlib.List.getAt(table, idx) with | None -> 0 | Some(item) -> let c = Stdlib.Tuple2.first(item) in let p = Stdlib.Tuple2.second(item) in if r < p then c else if idx + 1 >= Stdlib.List.length(table) then c else selectRandom(table, r, idx + 1) let table = [(97, 0.27), (99, 0.12), (103, 0.12), (116, 0.27)] in let cumulative = makeCumulative(table, 0.0) in let newSeed = (1 * 3877 + 29573) % 139968 in let r = Stdlib.Int64.toFloat(newSeed) / 139968.0 in selectRandom(cumulative, r, 0) = 97

// =====================================================
// Lists of Strings
// =====================================================

// List of strings - basic
match ["hello", "world"] with | [a, b] -> a ++ " " ++ b | _ -> "" = hello world

// Single string in list
match ["test"] with | [s] -> s | _ -> "" = test

// Three strings
match ["a", "b", "c"] with | [x, y, z] -> x ++ y ++ z | _ -> "" = abc

// =====================================================
// Lists of Bools
// =====================================================

// List of bools - all true
match [true, true, true] with | [a, b, c] -> if a && b && c then 1 else 0 | _ -> -1 = 1

// List of bools - mixed
match [true, false] with | [a, b] -> if a && b then 1 else 0 | _ -> -1 = 0

// =====================================================
// Recursive Functions on Complex Element Types
// =====================================================

// Sum list of floats recursively
// DISABLED (same float list bug): def sumFloats(xs: List<Float>) : Float = match xs with | [] -> 0.0 | [h, ...t] -> h + sumFloats(t)
// DISABLED: sumFloats([1.0, 2.0, 3.0, 4.0]) = stdout="10.00\n"

// Concatenate list of strings
def concatStrings(xs: List<String>) : String = match xs with | [] -> "" | [h, ...t] -> h ++ concatStrings(t)
concatStrings(["a", "b", "c"]) = abc

// =====================================================
// Middle Spine Access Tests (6+ element lists)
// =====================================================
// For lists with 6+ elements, elements 2-3 are stored in the middle spine
// (a NODE2 or NODE3). These tests verify the tree measure is correctly
// calculated for navigating to middle elements.

// Access element at index 2 (first element in middle NODE2)
Stdlib.Option.withDefault(Stdlib.List.getAt([1, 2, 3, 4, 5, 6], 2), 0) = 3

// Access element at index 3 (second element in middle NODE2)
Stdlib.Option.withDefault(Stdlib.List.getAt([1, 2, 3, 4, 5, 6], 3), 0) = 4
