// Equality Tests - Structural equality for different types
//
// Tests covering:
// - Integer equality
// - Boolean equality
// - Tuple equality
// - Record equality
// - Enum equality

// ===================================================================
// Integer Equality
// ===================================================================
1 == 1 = true
1 == 2 = false
5 == 5 = true
0 == 0 = true

1 != 2 = true
1 != 1 = false

// ===================================================================
// Boolean Equality
// ===================================================================
true == true = true
true == false = false
false == false = true
false == true = false

true != false = true
true != true = false

// ===================================================================
// Tuple Equality
// ===================================================================

// Two-element tuples
(1, 2) == (1, 2) = true
(1, 2) == (1, 3) = false
(1, 2) == (2, 2) = false
(1, 2) != (1, 3) = true
(1, 2) != (1, 2) = false

// Three-element tuples
(1, 2, 3) == (1, 2, 3) = true
(1, 2, 3) == (1, 2, 4) = false
(1, 2, 3) != (1, 2, 4) = true

// Tuples with booleans
(true, false) == (true, false) = true
(true, false) == (false, true) = false

// Tuples in variables
let a = (1, 2) in let b = (1, 2) in a == b = true
let a = (1, 2) in let b = (1, 3) in a == b = false

// Tuple equality in conditionals
if (1, 2) == (1, 2) then 1 else 0 = 1
if (1, 2) == (1, 3) then 1 else 0 = 0

// ===================================================================
// Record Equality
// ===================================================================

// Same records are equal
type Point = { x: Int64, y: Int64 } Point { x = 1, y = 2 } == Point { x = 1, y = 2 } = true

// Different field values are not equal
type Point = { x: Int64, y: Int64 } Point { x = 1, y = 2 } == Point { x = 1, y = 3 } = false
type Point = { x: Int64, y: Int64 } Point { x = 1, y = 2 } == Point { x = 2, y = 2 } = false

// Inequality
type Point = { x: Int64, y: Int64 } Point { x = 1, y = 2 } != Point { x = 3, y = 4 } = true
type Point = { x: Int64, y: Int64 } Point { x = 1, y = 2 } != Point { x = 1, y = 2 } = false

// Records in variables
type Point = { x: Int64, y: Int64 } let a = Point { x = 1, y = 2 } in let b = Point { x = 1, y = 2 } in a == b = true
type Point = { x: Int64, y: Int64 } let a = Point { x = 1, y = 2 } in let b = Point { x = 1, y = 3 } in a == b = false

// Three-field records
type Vec3 = { x: Int64, y: Int64, z: Int64 } Vec3 { x = 1, y = 2, z = 3 } == Vec3 { x = 1, y = 2, z = 3 } = true
type Vec3 = { x: Int64, y: Int64, z: Int64 } Vec3 { x = 1, y = 2, z = 3 } == Vec3 { x = 1, y = 2, z = 4 } = false

// Record equality in conditionals
type Point = { x: Int64, y: Int64 } if Point { x = 1, y = 2 } == Point { x = 1, y = 2 } then 1 else 0 = 1
type Point = { x: Int64, y: Int64 } if Point { x = 1, y = 2 } == Point { x = 1, y = 3 } then 1 else 0 = 0

// ===================================================================
// Enum Equality (simple - no payload)
// ===================================================================
type Color = Red | Green | Blue Red == Red = true
type Color = Red | Green | Blue Red == Blue = false
type Color = Red | Green | Blue Green == Green = true
type Color = Red | Green | Blue Red != Blue = true
type Color = Red | Green | Blue Red != Red = false

// Enum in variables
type Color = Red | Green | Blue let a = Red in let b = Red in a == b = true
type Color = Red | Green | Blue let a = Red in let b = Blue in a == b = false

// Enum in conditionals
type Color = Red | Green | Blue if Red == Red then 1 else 0 = 1
type Color = Red | Green | Blue if Red == Blue then 1 else 0 = 0

// Enum with payload equality
type BoxedList = EmptyBox | FullBox of List<Int64> FullBox([1, 2]) == FullBox([1, 2]) = true

// ===================================================================
// Nested Structural Equality
// ===================================================================

// Tuple of tuples
((1, 2), (3, 4)) == ((1, 2), (3, 4)) = true
((1, 2), (3, 4)) == ((1, 2), (3, 5)) = false

// Record with tuple field
type PointPair = { p1: (Int64, Int64), p2: (Int64, Int64) } PointPair { p1 = (1, 2), p2 = (3, 4) } == PointPair { p1 = (1, 2), p2 = (3, 4) } = true
type PointPair = { p1: (Int64, Int64), p2: (Int64, Int64) } PointPair { p1 = (1, 2), p2 = (3, 4) } == PointPair { p1 = (1, 2), p2 = (3, 5) } = false

// ===================================================================
// Deeply Nested Polymorphic Sum Equality With Records
// ===================================================================
type WrapEq1<t> = WNoneEq1 | WSomeEq1 of t type EitherEq1<a, b> = LeftEq1 of a | RightEq1 of b type RecEq1 = { left: WrapEq1<Int64>, mid: EitherEq1<Int64, Int64>, right: WrapEq1<Int64> } type DeepEq1<t, u> = DLeafEq1 of (RecEq1, t, u) | DNodeEq1 of (RecEq1, EitherEq1<t, u>, RecEq1) let a = DNodeEq1((RecEq1 { left = WSomeEq1(1), mid = LeftEq1(10), right = WNoneEq1 }, LeftEq1(42), RecEq1 { left = WSomeEq1(2), mid = RightEq1(99), right = WSomeEq1(3) })) in let b = DNodeEq1((RecEq1 { left = WSomeEq1(1), mid = LeftEq1(10), right = WNoneEq1 }, LeftEq1(42), RecEq1 { left = WSomeEq1(2), mid = RightEq1(99), right = WSomeEq1(3) })) in a == b = true
type WrapEq2<t> = WNoneEq2 | WSomeEq2 of t type EitherEq2<a, b> = LeftEq2 of a | RightEq2 of b type RecEq2 = { left: WrapEq2<Int64>, mid: EitherEq2<Int64, Int64>, right: WrapEq2<Int64> } type DeepEq2<t, u> = DLeafEq2 of (RecEq2, t, u) | DNodeEq2 of (RecEq2, EitherEq2<t, u>, RecEq2) let a = DNodeEq2((RecEq2 { left = WSomeEq2(1), mid = LeftEq2(10), right = WNoneEq2 }, LeftEq2(42), RecEq2 { left = WSomeEq2(2), mid = RightEq2(99), right = WSomeEq2(3) })) in let b = DNodeEq2((RecEq2 { left = WSomeEq2(1), mid = LeftEq2(11), right = WNoneEq2 }, LeftEq2(42), RecEq2 { left = WSomeEq2(2), mid = RightEq2(99), right = WSomeEq2(3) })) in a == b = false
type BoxEq3<t> = BoxNoneEq3 | BoxSomeEq3 of t type ChoiceEq3<a, b> = ChoiceLeftEq3 of a | ChoiceRightEq3 of b type RecEq3 = { one: BoxEq3<Int64>, two: ChoiceEq3<Int64, Int64>, three: (BoxEq3<Int64>, ChoiceEq3<Int64, Int64>) } type DeepEq3<t> = WrapRecEq3 of (RecEq3, BoxEq3<t>, RecEq3) | EmptyRecEq3 let a = WrapRecEq3((RecEq3 { one = BoxSomeEq3(11), two = ChoiceRightEq3(22), three = (BoxSomeEq3(33), ChoiceLeftEq3(44)) }, BoxSomeEq3(55), RecEq3 { one = BoxNoneEq3, two = ChoiceLeftEq3(66), three = (BoxSomeEq3(77), ChoiceRightEq3(88)) })) in let b = WrapRecEq3((RecEq3 { one = BoxSomeEq3(11), two = ChoiceRightEq3(22), three = (BoxSomeEq3(33), ChoiceLeftEq3(44)) }, BoxSomeEq3(55), RecEq3 { one = BoxNoneEq3, two = ChoiceLeftEq3(66), three = (BoxSomeEq3(77), ChoiceRightEq3(88)) })) in a == b = true
type BoxEq4<t> = BoxNoneEq4 | BoxSomeEq4 of t type ChoiceEq4<a, b> = ChoiceLeftEq4 of a | ChoiceRightEq4 of b type RecEq4 = { one: BoxEq4<Int64>, two: ChoiceEq4<Int64, Int64>, three: (BoxEq4<Int64>, ChoiceEq4<Int64, Int64>) } type DeepEq4<t> = WrapRecEq4 of (RecEq4, BoxEq4<t>, RecEq4) | EmptyRecEq4 let a = WrapRecEq4((RecEq4 { one = BoxSomeEq4(11), two = ChoiceRightEq4(22), three = (BoxSomeEq4(33), ChoiceLeftEq4(44)) }, BoxSomeEq4(55), RecEq4 { one = BoxNoneEq4, two = ChoiceLeftEq4(66), three = (BoxSomeEq4(77), ChoiceRightEq4(88)) })) in let b = WrapRecEq4((RecEq4 { one = BoxSomeEq4(11), two = ChoiceRightEq4(22), three = (BoxSomeEq4(33), ChoiceLeftEq4(44)) }, BoxSomeEq4(55), RecEq4 { one = BoxNoneEq4, two = ChoiceLeftEq4(66), three = (BoxSomeEq4(78), ChoiceRightEq4(88)) })) in a != b = true
