// Equality Tests - Structural equality for different types
//
// Tests covering:
// - Integer equality
// - Boolean equality
// - Tuple equality
// - Record equality
// - Enum equality

// ===================================================================
// Integer Equality
// ===================================================================
1 == 1 = true
1 == 2 = false
5 == 5 = true
0 == 0 = true

1 != 2 = true
1 != 1 = false

// ===================================================================
// Boolean Equality
// ===================================================================
true == true = true
true == false = false
false == false = true
false == true = false

true != false = true
true != true = false

// ===================================================================
// Tuple Equality
// ===================================================================

// Two-element tuples
(1, 2) == (1, 2) = true
(1, 2) == (1, 3) = false
(1, 2) == (2, 2) = false
(1, 2) != (1, 3) = true
(1, 2) != (1, 2) = false

// Three-element tuples
(1, 2, 3) == (1, 2, 3) = true
(1, 2, 3) == (1, 2, 4) = false
(1, 2, 3) != (1, 2, 4) = true

// Tuples with booleans
(true, false) == (true, false) = true
(true, false) == (false, true) = false

// Tuples in variables
let a = (1, 2) in let b = (1, 2) in a == b = true
let a = (1, 2) in let b = (1, 3) in a == b = false

// Tuple equality in conditionals
if (1, 2) == (1, 2) then 1 else 0 = 1
if (1, 2) == (1, 3) then 1 else 0 = 0

// ===================================================================
// Record Equality
// ===================================================================

// Same records are equal
type Point = { x: Int64, y: Int64 } Point { x = 1, y = 2 } == Point { x = 1, y = 2 } = true

// Different field values are not equal
type Point = { x: Int64, y: Int64 } Point { x = 1, y = 2 } == Point { x = 1, y = 3 } = false
type Point = { x: Int64, y: Int64 } Point { x = 1, y = 2 } == Point { x = 2, y = 2 } = false

// Inequality
type Point = { x: Int64, y: Int64 } Point { x = 1, y = 2 } != Point { x = 3, y = 4 } = true
type Point = { x: Int64, y: Int64 } Point { x = 1, y = 2 } != Point { x = 1, y = 2 } = false

// Records in variables
type Point = { x: Int64, y: Int64 } let a = Point { x = 1, y = 2 } in let b = Point { x = 1, y = 2 } in a == b = true
type Point = { x: Int64, y: Int64 } let a = Point { x = 1, y = 2 } in let b = Point { x = 1, y = 3 } in a == b = false

// Three-field records
type Vec3 = { x: Int64, y: Int64, z: Int64 } Vec3 { x = 1, y = 2, z = 3 } == Vec3 { x = 1, y = 2, z = 3 } = true
type Vec3 = { x: Int64, y: Int64, z: Int64 } Vec3 { x = 1, y = 2, z = 3 } == Vec3 { x = 1, y = 2, z = 4 } = false

// Record equality in conditionals
type Point = { x: Int64, y: Int64 } if Point { x = 1, y = 2 } == Point { x = 1, y = 2 } then 1 else 0 = 1
type Point = { x: Int64, y: Int64 } if Point { x = 1, y = 2 } == Point { x = 1, y = 3 } then 1 else 0 = 0

// ===================================================================
// Enum Equality (simple - no payload)
// ===================================================================
type Color = Red | Green | Blue Red == Red = true
type Color = Red | Green | Blue Red == Blue = false
type Color = Red | Green | Blue Green == Green = true
type Color = Red | Green | Blue Red != Blue = true
type Color = Red | Green | Blue Red != Red = false

// Enum in variables
type Color = Red | Green | Blue let a = Red in let b = Red in a == b = true
type Color = Red | Green | Blue let a = Red in let b = Blue in a == b = false

// Enum in conditionals
type Color = Red | Green | Blue if Red == Red then 1 else 0 = 1
type Color = Red | Green | Blue if Red == Blue then 1 else 0 = 0

// Enum with payload equality
type BoxedList = EmptyBox | FullBox of List<Int64> FullBox([1, 2]) == FullBox([1, 2]) = true

// ===================================================================
// Nested Structural Equality
// ===================================================================

// Tuple of tuples
((1, 2), (3, 4)) == ((1, 2), (3, 4)) = true
((1, 2), (3, 4)) == ((1, 2), (3, 5)) = false

// Record with tuple field
type PointPair = { p1: (Int64, Int64), p2: (Int64, Int64) } PointPair { p1 = (1, 2), p2 = (3, 4) } == PointPair { p1 = (1, 2), p2 = (3, 4) } = true
type PointPair = { p1: (Int64, Int64), p2: (Int64, Int64) } PointPair { p1 = (1, 2), p2 = (3, 4) } == PointPair { p1 = (1, 2), p2 = (3, 5) } = false
type PolyRecA<t, u> = { first: t, second: u } PolyRecA { first = 1, second = true } == PolyRecA { first = 1, second = true } = true

// ===================================================================
// Deeply Nested Polymorphic Sum Equality With Records
// ===================================================================
type WrapEq1<t> = WNoneEq1 | WSomeEq1 of t type EitherEq1<a, b> = LeftEq1 of a | RightEq1 of b type RecEq1<a, b, c> = { left: WrapEq1<a>, mid: EitherEq1<b, c>, right: WrapEq1<c> } let a = RecEq1 { left = WSomeEq1(1), mid = LeftEq1(7), right = WSomeEq1(WSomeEq1(9)) } in let b = RecEq1 { left = WSomeEq1(1), mid = LeftEq1(7), right = WSomeEq1(WSomeEq1(9)) } in a == b = true
type WrapEq2<t> = WNoneEq2 | WSomeEq2 of t type EitherEq2<a, b> = LeftEq2 of a | RightEq2 of b type RecEq2<a, b, c> = { left: WrapEq2<a>, mid: EitherEq2<b, c>, right: WrapEq2<c> } let a = RecEq2 { left = WSomeEq2(1), mid = LeftEq2(7), right = WSomeEq2(WSomeEq2(9)) } in let b = RecEq2 { left = WSomeEq2(1), mid = LeftEq2(7), right = WSomeEq2(WSomeEq2(10)) } in a == b = false
type BoxEq3<t> = BoxNoneEq3 | BoxSomeEq3 of t type ChoiceEq3<a, b> = ChoiceLeftEq3 of a | ChoiceRightEq3 of b type RecEq3<a, b, c> = { one: BoxEq3<a>, two: ChoiceEq3<b, c>, three: (BoxEq3<c>, ChoiceEq3<a, b>) } let a = RecEq3 { one = BoxSomeEq3(11), two = ChoiceLeftEq3("x"), three = (BoxSomeEq3(22), ChoiceRightEq3("x")) } in let b = RecEq3 { one = BoxSomeEq3(11), two = ChoiceLeftEq3("x"), three = (BoxSomeEq3(22), ChoiceRightEq3("x")) } in a == b = true
type BoxEq4<t> = BoxNoneEq4 | BoxSomeEq4 of t type ChoiceEq4<a, b> = ChoiceLeftEq4 of a | ChoiceRightEq4 of b type RecEq4<a, b, c> = { one: BoxEq4<a>, two: ChoiceEq4<b, c>, three: (BoxEq4<c>, ChoiceEq4<a, b>) } let a = RecEq4 { one = BoxSomeEq4(11), two = ChoiceLeftEq4("x"), three = (BoxSomeEq4(22), ChoiceRightEq4("x")) } in let b = RecEq4 { one = BoxSomeEq4(11), two = ChoiceLeftEq4("x"), three = (BoxSomeEq4(22), ChoiceRightEq4("y")) } in a != b = true
