// MIR Optimization Tests
// Tests loop-invariant code motion in MIR (SSA).

---NAME---
licm_hoist_hash
---INPUT---
def loop(n: Int64, acc: Int64) : Int64 =
    if n < 1 then acc
    else
        let h = __hash<String>("hello") in
        loop(n - 1, acc + h)

loop(3, 0)
---EXPECTED---
Function loop:
  loop_entry:
    jump loop_body
  loop_L1:
    v10015 <- Call(__hash_str, [str[hello]])
    v10016 <- v10013 - 1 : TInt64
    v10017 <- v10012 + v10015 : TInt64
    v10018 <- v10016 : TInt64
    v10019 <- v10017 : TInt64
    jump loop_body
  loop_L2:
    ret v10012
  loop_body:
    v10012 <- Phi([(v1, loop_entry), (v10019, loop_L1)]) : TInt64
    v10013 <- Phi([(v0, loop_entry), (v10018, loop_L1)]) : TInt64
    v10014 <- v10013 < 1 : TInt64
    branch v10014 ? loop_L2 : loop_L1
Function _start:
  _start_body:
    v10008 <- Call(loop, [3, 0])
    Print(v10008, type=TInt64)
    ret v10008

---NAME---
licm_skip_constant_move
---INPUT---
def loop(n: Int64) : Int64 =
    if n < 1 then 0
    else loop(1)

loop(2)
---EXPECTED---
Function loop:
  loop_entry:
    jump loop_body
  loop_L1:
    v10006 <- 1 : TInt64
    jump loop_body
  loop_L2:
    ret 0
  loop_body:
    v10004 <- Phi([(v0, loop_entry), (v10006, loop_L1)]) : TInt64
    v10005 <- v10004 < 1 : TInt64
    branch v10005 ? loop_L2 : loop_L1
Function _start:
  _start_body:
    v10003 <- Call(loop, [2])
    Print(v10003, type=TInt64)
    ret v10003

---NAME---
const_branch_elimination_bitand
---INPUT---
def pick(n: Int64) : Int64 =
    let masked = n & 0 in
    if masked == 0 then 1 else 2

pick(42)
---EXPECTED---
Function pick:
  pick_entry:
    jump pick_L2
  pick_L2:
    ret 1
Function _start:
  _start_body:
    v10004 <- Call(pick, [42])
    Print(v10004, type=TInt64)
    ret v10004

---NAME---
licm_hoist_tuple_load
---INPUT---
def loop(n: Int64, acc: Int64, t: (Int64, Int64)) : Int64 =
    if n < 1 then acc
    else
        let v = t.0 in
        loop(n - 1, acc + v, t)

loop(3, 0, (10, 20))
---EXPECTED---
Function loop:
  loop_entry:
    v10023 <- HeapLoad(v2, 0)
    jump loop_body
  loop_L1:
    v10024 <- v10021 - 1 : TInt64
    v10025 <- v10020 + v10023 : TInt64
    v10029 <- v10024 : TInt64
    v10030 <- v10025 : TInt64
    v10031 <- v10019 : TTuple [TInt64; TInt64]
    jump loop_body
  loop_L2:
    ret v10020
  loop_body:
    v10019 <- Phi([(v2, loop_entry), (v10031, loop_L1)]) : TTuple [TInt64; TInt64]
    v10020 <- Phi([(v1, loop_entry), (v10030, loop_L1)]) : TInt64
    v10021 <- Phi([(v0, loop_entry), (v10029, loop_L1)]) : TInt64
    v10022 <- v10021 < 1 : TInt64
    branch v10022 ? loop_L2 : loop_L1
Function _start:
  _start_body:
    v10010 <- HeapAlloc(16)
    HeapStore(v10010, 0, 10)
    HeapStore(v10010, 8, 20)
    v10011 <- Call(loop, [3, 0, v10010])
    RefCountDec(v10010, size=16)
    Print(v10011, type=TInt64)
    ret v10011
