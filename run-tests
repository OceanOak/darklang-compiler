#!/bin/bash
# run-tests - Wrapper script to build and run the Dark compiler test suite
#
# Usage: ./run-tests [OPTIONS]
#
# Options:
#   --filter=PATTERN   Run only tests matching PATTERN (case-insensitive)
#   --verification     Enable verification/stress tests
#   --parser-pretty-roundtrip  Enable parser/pretty-printer roundtrip corpus test
#   --build-only       Only build, don't run tests
#   --quiet            Quiet mode: print "success" or list failed tests
#   --verbose          Print failing tests as soon as they occur
#   -h, --help         Show this help message
#
# Examples:
#   ./run-tests                      Run all tests
#   ./run-tests --filter=tuple       Run tests with 'tuple' in the name
#   ./run-tests --filter=string      Run tests with 'string' in the name
#   ./run-tests --filter=list

set -e

# Parse arguments
FILTER=""
BUILD_ONLY=false
QUIET=false
HELP=false
TEST_ARGS=()

while [[ $# -gt 0 ]]; do
    case $1 in
        --filter=*)
            FILTER="${1#*=}"
            TEST_ARGS+=("--filter=$FILTER")
            shift
            ;;
        --verification)
            TEST_ARGS+=("--verification")
            shift
            ;;
        --parser-pretty-roundtrip)
            TEST_ARGS+=("--parser-pretty-roundtrip")
            shift
            ;;
        --build-only)
            BUILD_ONLY=true
            shift
            ;;
        --quiet)
            QUIET=true
            shift
            ;;
        --verbose)
            TEST_ARGS+=("--verbose")
            shift
            ;;
        -h|--help)
            HELP=true
            shift
            ;;
        *)
            # Pass unknown args to test runner
            TEST_ARGS+=("$1")
            shift
            ;;
    esac
done

# Show help
if [ "$HELP" = true ]; then
    echo "Usage: ./run-tests [OPTIONS]"
    echo ""
    echo "Build and run the Dark compiler test suite."
    echo ""
    echo "Options:"
    echo "  --filter=PATTERN   Run only tests matching PATTERN (case-insensitive substring)"
    echo "  --verification     Enable verification/stress tests"
    echo "  --parser-pretty-roundtrip  Enable parser/pretty-printer roundtrip corpus test"
    echo "  --build-only       Only build, don't run tests"
    echo "  --quiet            Quiet mode: print 'success' or list failed tests"
    echo "  --verbose          Print failing tests as soon as they occur"
    echo "  -h, --help         Show this help message"
    echo ""
    echo "Examples:"
    echo "  ./run-tests                          Run all tests"
    echo "  ./run-tests --filter=tuple           Run tests with 'tuple' in the name"
    echo "  ./run-tests --filter=string          Run tests with 'string' in the name"
    echo "  ./run-tests --filter=List.map        Run List.map tests"
    echo "  ./run-tests --filter=list"
    echo ""
    echo "Test categories matched by filter:"
    echo "  tuple, record, list, string, float, int, bool"
    echo "  closure, match, adt, generic, stdlib"
    echo "  ANF, MIR, LIR, ARM64, Encoding, Binary"
    exit 0
fi

# Get script directory
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR"

. "$SCRIPT_DIR/scripts/test-common.sh"

# Build
if [ "$QUIET" = true ]; then
    if ! build_tests "$SCRIPT_DIR" "$SCRIPT_DIR/NuGet.Config" > /dev/null 2>&1; then
        echo "build failed"
        exit 1
    fi
else
    if ! build_tests "$SCRIPT_DIR" "$SCRIPT_DIR/NuGet.Config"; then
        exit 1
    fi
fi

if [ "$BUILD_ONLY" = true ]; then
    if [ "$QUIET" != true ]; then
        echo "Build-only mode, skipping tests."
    fi
    exit 0
fi

# Find and run the test executable
TEST_EXE="$(find_test_exe "$SCRIPT_DIR" "Try running the build first.")" || exit 1

# Run tests
if [ "$QUIET" = true ]; then
    EXIT_CODE=0
    OUTPUT=$("$TEST_EXE" "${TEST_ARGS[@]}" 2>&1) || EXIT_CODE=$?
    # Check for failures by looking for FAIL lines
    FAILED=$(echo "$OUTPUT" | grep -E "^\s*FAIL\s+" || true)
    if [ $EXIT_CODE -ne 0 ] || [ -n "$FAILED" ]; then
        echo "failed tests:"
        if [ -n "$FAILED" ]; then
            echo "$FAILED"
        else
            echo "(test runner exited with code $EXIT_CODE)"
        fi
        exit 1
    else
        echo "success"
        exit 0
    fi
else
    run_tests "$TEST_EXE" "${TEST_ARGS[@]}"
fi
